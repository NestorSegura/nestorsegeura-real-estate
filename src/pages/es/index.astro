---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/utils';
import { getHomepageForLocale } from '../../lib/sanity';

const locale = 'es' as const;
const t = useTranslations(locale);

const { page, isFallback } = await getHomepageForLocale(locale);

if (!page) {
  console.warn('[07-02] No homepage document found in Sanity for locale "es" (or "de" fallback). Rendering placeholder.');
}
---
<BaseLayout title={page?.title ?? t('hero.title')} locale={locale}>
  <nav>
    <ul>
      <li>{t('nav.home')}</li>
      <li>{t('nav.services')}</li>
      <li>{t('nav.about')}</li>
      <li>{t('nav.contact')}</li>
      <li>{t('nav.blog')}</li>
    </ul>
  </nav>
  <main>
    {isFallback && page && (
      <div class="translation-banner" role="status">
        Esta página aún no está traducida — mostrando la versión en alemán.
      </div>
    )}
    {page ? (
      <>
        <h1>{page.title ?? t('hero.title')}</h1>
        <p>{t('hero.subtitle')}</p>
        <p class="debug-sections">sections: {page.sections?.length ?? 0}</p>
      </>
    ) : (
      <>
        <h1>{t('hero.title')}</h1>
        <p>{t('hero.subtitle')}</p>
        <p class="debug-sections">sections: 0</p>
      </>
    )}
  </main>
</BaseLayout>
