---
import BaseLayout from '../../layouts/BaseLayout.astro'
import PageBuilder from '../../components/blocks/PageBuilder.astro'
import { getHomepageWithSections, getSiteSettings } from '../../lib/sanity'
import { buildMeta, buildPersonSchema } from '../../lib/seo'

const locale = 'es' as const
const page = await getHomepageWithSections(locale)
const settings = await getSiteSettings()
const sections = page?.sections ?? []

const SITE_URL =
  (import.meta.env.PUBLIC_SITE_URL as string | undefined) ?? 'https://realestatestrategy.eu'

const meta = buildMeta({
  pageSeo: page?.seo,
  settings,
  fallbackTitle: settings?.siteName ?? 'realestatestrategy.eu',
  fallbackDescription: settings?.tagline,
  ogImageRef: (page?.seo as any)?.ogImage ?? settings?.seo?.ogImage,
  currentUrl: Astro.url.href,
})

const personSchema = buildPersonSchema(settings)

const hreflangUrls = {
  de: SITE_URL + '/',
  en: SITE_URL + '/en/',
  es: SITE_URL + '/es/',
}
---
<BaseLayout
  title={meta.title}
  locale={locale}
  description={meta.description}
  ogImage={meta.ogImage}
  canonical={meta.canonical}
  hreflangUrls={hreflangUrls}
  jsonLd={[personSchema]}
  heroBleed
>
  <PageBuilder {sections} {locale} />
</BaseLayout>
