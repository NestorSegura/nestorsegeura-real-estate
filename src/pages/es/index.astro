---
import '../../styles/global.css';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('es');
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{t('hero.title')}</title>
  </head>
  <body>
    <nav>
      <ul>
        <li>{t('nav.home')}</li>
        <li>{t('nav.services')}</li>
        <li>{t('nav.about')}</li>
        <li>{t('nav.contact')}</li>
        <li>{t('nav.blog')}</li>
      </ul>
    </nav>
    <main>
      <h1>{t('hero.title')}</h1>
      <p>{t('hero.subtitle')}</p>
    </main>
  </body>
</html>
