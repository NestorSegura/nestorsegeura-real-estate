---
import BaseLayout from '../layouts/BaseLayout.astro';
import LegalStub from '../components/legal/LegalStub.astro';
import { useTranslations } from '../i18n/utils';

const locale = 'de' as const;
const t = useTranslations(locale);
---
<BaseLayout title={t('legal.datenschutzTitle')} locale={locale}>
  <main>
    <LegalStub locale={locale} titleKey="legal.datenschutzTitle" />
  </main>
</BaseLayout>
