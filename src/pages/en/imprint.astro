      <address>
        Nestor Segura<br />
        Heidmühlenweg 54<br />
        25336 Elmshorn<br />
        Germany
      </address>

      <h2>Contact</h2>
      <p>
        Email: <a href="mailto:contact@nestorsegura.com">contact@nestorsegura.com</a>
      </p>

      <h2>VAT identification number</h2>
      <p>
        VAT ID pursuant to § 27 a German Value-Added Tax Act (UStG):<br />
        DE352032325
      </p>

