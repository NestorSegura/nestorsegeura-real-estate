---
import { type Locale } from '../../i18n/utils';
import { useTranslations } from '../../i18n/utils';

interface Props {
  locale: Locale;
  titleKey: 'legal.impressumTitle' | 'legal.datenschutzTitle' | 'legal.agbTitle';
}

const { locale, titleKey } = Astro.props;
const t = useTranslations(locale);
---
<section class="legal-stub">
  <div class="legal-stub__inner">
    <h1 class="legal-stub__title">{t(titleKey)}</h1>
    <p class="legal-stub__notice">{t('legal.placeholderNotice')}</p>
    <p class="legal-stub__body">{t('legal.placeholderBody')}</p>
  </div>
</section>

<style>
  .legal-stub {
    padding: 4rem 1.5rem 6rem;
    max-width: 48rem;
    margin: 0 auto;
  }
  .legal-stub__title {
    font-family: 'Clash Display', system-ui, sans-serif;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 600;
    line-height: 1.1;
    margin: 0 0 1.5rem;
  }
  .legal-stub__notice {
    padding: 1rem 1.25rem;
    background: #f5f5f3;
    border-left: 3px solid #241552;
    border-radius: 0.25rem;
    font-size: 0.95rem;
    line-height: 1.5;
    margin: 0 0 2rem;
  }
  .legal-stub__body {
    font-size: 1rem;
    line-height: 1.6;
    color: rgba(19, 19, 19, 0.75);
    margin: 0;
  }
</style>
