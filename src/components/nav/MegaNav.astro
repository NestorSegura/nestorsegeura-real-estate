---
/**
 * MegaNav — osmo.supply "mega-nav directional hover" adapted for nestorsegura.
 *
 * DOM structure matches osmo VERBATIM (see .planning/phases/09-interactive-islands/osmo-reference.md).
 * Only changes from osmo original:
 *   - #6840ff  → oklch(0.58 0.20 290) (Jibemates purple)
 *   - Haffer Mono → Chivo / Clash Display
 *   - Log in / Get Started → DE|EN|ES locale switcher + "Termin buchen" CTA
 *   - Flat links (Blog/Analyse/Kontakt) with no dropdown toggles in Phase 9
 *   - Empty dropdown wrapper/container/bg preserved (controller queries them)
 *
 * GSAP loaded lazily from CDN (same guard pattern as StackingCards.astro).
 * Locale switcher hrefs are pre-computed at build time via data-href attributes.
 */

interface Props {
  locale: 'de' | 'en' | 'es';
  navItems: Array<{ href: string; label: string }>;
  ctaLabel: string;
  ctaHref: string;
  localeUrls: Record<'de' | 'en' | 'es', string>;
}

const { locale, navItems, ctaLabel, ctaHref, localeUrls } = Astro.props;

const locales = ['de', 'en', 'es'] as const;

const localeLabels: Record<'de' | 'en' | 'es', string> = {
  de: 'DE',
  en: 'EN',
  es: 'ES',
};
---

<!-- osmo mega-nav directional hover — exact DOM per osmo-reference.md -->
<nav data-menu-open="false" data-menu-wrap class="mega-nav" aria-label="Main navigation">

  <div class="mega-nav__bar">
    <div class="mega-nav__container">
      <div class="mega-nav__bar-start">

        <!-- Logo -->
        <a data-menu-logo href={localeUrls[locale]} class="mega-nav__bar-logo w-inline-block" aria-label="Homepage">
          <span class="mega-nav__bar-logo-text">NS</span>
          <span class="mega-nav__bar-logo-label">Real Estate Strategy</span>
        </a>

        <!-- Nav list: primary links + actions (osmo: data-nav-list data-mobile-nav) -->
        <div data-nav-list data-mobile-nav class="mega-nav__bar-inner">

          <!-- Primary flat links -->
          <ul class="mega-nav__bar-list">
            {navItems.map((item) => (
              <li data-nav-list-item>
                <a href={item.href} class="mega-nav__bar-link w-inline-block">
                  <span class="mega-nav__bar-link-label">{item.label}</span>
                </a>
              </li>
            ))}
          </ul>

          <!-- Actions: locale switcher + CTA -->
          <ul class="mega-nav__bar-list is--actions">
            <!-- Locale switcher -->
            <li class="mega-nav__bar-action" data-locale-switcher>
              <div role="group" aria-label="Language" class="locale-switcher">
                {locales.map((l) => (
                  <button
                    data-href={localeUrls[l]}
                    data-locale={l}
                    class={`locale-btn${l === locale ? ' is-active' : ''}`}
                    aria-label={`Switch to ${localeLabels[l]}`}
                    aria-current={l === locale ? 'true' : undefined}
                    disabled={l === locale ? true : undefined}
                  >
                    {localeLabels[l]}
                  </button>
                ))}
              </div>
            </li>
            <!-- CTA -->
            <li class="mega-nav__bar-action">
              <a href={ctaHref} class="mega-nav__bar-cta w-inline-block" target="_blank" rel="noopener noreferrer">
                <span class="mega-nav__bar-link-label">{ctaLabel}</span>
                <svg class="mega-nav__bar-link-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </li>
          </ul>

        </div><!-- /data-nav-list -->

        <!-- Burger (mobile only) -->
        <div class="mega-nav__bar-end">
          <button data-burger-toggle aria-label="toggle menu" aria-expanded="false" class="mega-nav__burger">
            <span data-burger-line="top" class="mega-nav__burger-line"></span>
            <span data-burger-line="mid" class="mega-nav__burger-line"></span>
            <span data-burger-line="bot" class="mega-nav__burger-line"></span>
          </button>
        </div>

        <!-- Mobile back button (REQUIRED — controller queries [data-mobile-back]) -->
        <div data-mobile-back class="mega-nav__back">
          <button aria-label="back to menu" class="mega-nav__bar-link is--back">
            <svg class="mega-nav__bar-link-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M10 12L6 8l4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span class="mega-nav__bar-link-label">Back</span>
          </button>
        </div>

      </div><!-- /mega-nav__bar-start -->
    </div><!-- /mega-nav__container -->
  </div><!-- /mega-nav__bar -->

  <!--
    Dropdown wrapper MUST EXIST even with no panels in Phase 9.
    The controller querySelects [data-dropdown-wrapper], [data-dropdown-container],
    [data-dropdown-bg] — missing elements would throw. Empty is fine.
    Future: add <div data-nav-content="blog" ...> panels here.
  -->
  <div data-dropdown-wrapper class="mega-nav__dropdown-wrapper">
    <div data-dropdown-container class="mega-nav__dropdown-container">
      <div data-dropdown-bg class="mega-nav__dropdown-bg"></div>
      <!-- NO panels in Phase 9 -->
    </div>
  </div>

  <!-- Backdrop — closes mobile menu on click -->
  <div data-menu-backdrop class="mega-nav__backdrop"></div>

</nav>

<!-- ── Styles (osmo verbatim with brand token swaps) ──────────────────── -->
<style is:global>
/* ================================================================
   MEGA-NAV — osmo.supply "mega-nav directional hover"
   Brand adaption for nestorsegura / Jibemates
   #6840ff → oklch(0.58 0.20 290)
   Haffer Mono → Chivo / Clash Display
   ================================================================ */

/* ── Reset ───────────────────────────────────────────────────── */
.mega-nav *,
.mega-nav *::before,
.mega-nav *::after {
  box-sizing: border-box;
}

/* ── Root nav wrapper ────────────────────────────────────────── */
.mega-nav {
  position: fixed;
  top: 1.25em;
  left: 0;
  right: 0;
  z-index: 1000;
  pointer-events: none;
}

/* ── Bar ─────────────────────────────────────────────────────── */
.mega-nav__bar {
  pointer-events: auto;
}

.mega-nav__container {
  display: flex;
  align-items: stretch;
  max-width: 90rem;
  margin: 0 auto;
  padding: 0 1.25em;
}

.mega-nav__bar-start {
  display: flex;
  align-items: center;
  width: 100%;
  padding: 0.75em 1.25em;
  background: rgba(19, 19, 19, 0.92);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-radius: 0.875rem;
  border: 1px solid rgba(255, 255, 255, 0.07);
  gap: 0;
}

/* ── Logo ────────────────────────────────────────────────────── */
.mega-nav__bar-logo {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  text-decoration: none;
  flex-shrink: 0;
  margin-right: 1.5rem;
}

.w-inline-block {
  display: inline-flex;
  align-items: center;
}

.mega-nav__bar-logo-text {
  font-family: "Clash Display", sans-serif;
  font-weight: 700;
  font-size: 1.25rem;
  color: oklch(0.58 0.20 290);
  letter-spacing: -0.02em;
  line-height: 1;
}

.mega-nav__bar-logo-label {
  font-family: "Chivo", sans-serif;
  font-size: 0.6875rem;
  font-weight: 400;
  color: rgba(239, 238, 236, 0.50);
  letter-spacing: 0.02em;
  white-space: nowrap;
}

/* ── Bar inner: nav lists ────────────────────────────────────── */
.mega-nav__bar-inner {
  display: flex;
  align-items: center;
  flex: 1;
  gap: 0;
}

.mega-nav__bar-list {
  display: flex;
  align-items: center;
  list-style: none;
  margin: 0;
  padding: 0;
  gap: 0.125rem;
}

/* Primary links: fill remaining space */
.mega-nav__bar-list:not(.is--actions) {
  flex: 1;
}

/* Actions list: right-aligned */
.mega-nav__bar-list.is--actions {
  gap: 0.625rem;
  flex-shrink: 0;
}

.mega-nav__bar-list-item,
[data-nav-list-item] {
  display: flex;
  align-items: center;
}

/* ── Nav links ───────────────────────────────────────────────── */
.mega-nav__bar-link {
  display: inline-flex;
  align-items: center;
  gap: 0.375rem;
  padding: 0.5em 0.875em;
  font-family: "Chivo", sans-serif;
  font-size: 0.9375rem;
  font-weight: 500;
  color: rgba(239, 238, 236, 0.75);
  text-decoration: none;
  border-radius: 0.5rem;
  white-space: nowrap;
  transition: color 0.18s ease, background-color 0.18s ease;
  cursor: pointer;
  background: none;
  border: none;
}

.mega-nav__bar-link:hover {
  color: #efeeec;
  background-color: rgba(255, 255, 255, 0.06);
}

.mega-nav__bar-link-label {
  line-height: 1;
}

.mega-nav__bar-link-icon {
  width: 1em;
  height: 1em;
  flex-shrink: 0;
}

/* ── Locale switcher ─────────────────────────────────────────── */
.locale-switcher {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 0.5rem;
  padding: 0.1875rem;
  gap: 0.0625rem;
}

.locale-btn {
  font-family: "Chivo", sans-serif;
  font-size: 0.6875rem;
  font-weight: 600;
  letter-spacing: 0.05em;
  color: rgba(239, 238, 236, 0.55);
  background: transparent;
  border: none;
  border-radius: 0.3125rem;
  padding: 0.3125em 0.5625em;
  cursor: pointer;
  transition: background-color 0.18s ease, color 0.18s ease;
  line-height: 1;
}

.locale-btn:hover:not(:disabled) {
  color: #efeeec;
  background-color: rgba(255, 255, 255, 0.09);
}

.locale-btn.is-active {
  background-color: oklch(0.58 0.20 290);
  color: #fff;
  cursor: default;
}

/* ── CTA ─────────────────────────────────────────────────────── */
.mega-nav__bar-cta {
  display: inline-flex;
  align-items: center;
  gap: 0.375rem;
  padding: 0.5625em 1.125em;
  font-family: "Clash Display", sans-serif;
  font-size: 0.875rem;
  font-weight: 600;
  color: #fff;
  background: oklch(0.58 0.20 290);
  border-radius: 0.5rem;
  text-decoration: none;
  white-space: nowrap;
  transition: background-color 0.18s ease, transform 0.14s ease;
  letter-spacing: -0.01em;
}

.mega-nav__bar-cta:hover {
  background: oklch(0.50 0.20 290);
  transform: translateY(-1px);
}

.mega-nav__bar-cta:active {
  transform: translateY(0);
}

/* ── Burger ──────────────────────────────────────────────────── */
.mega-nav__bar-end {
  display: none;
  align-items: center;
  flex-shrink: 0;
  margin-left: 0.75rem;
}

.mega-nav__burger {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 0;
  width: 2.25rem;
  height: 2.25rem;
  background: rgba(228, 224, 245, 0.10);
  border: none;
  border-radius: 0.5rem;
  cursor: pointer;
  padding: 0;
  transition: background-color 0.18s ease;
  position: relative;
}

.mega-nav__burger:hover {
  background: rgba(228, 224, 245, 0.15);
}

.mega-nav__burger-line {
  display: block;
  width: 1.125rem;
  height: 1.5px;
  background: rgba(239, 238, 236, 0.85);
  border-radius: 2px;
  position: absolute;
  transition: transform 0.3s ease, opacity 0.2s ease;
  transform-origin: center center;
}

/* Default burger line positions */
[data-burger-line="top"]  { transform: translateY(-0.25rem); }
[data-burger-line="mid"]  { transform: translateY(0); }
[data-burger-line="bot"]  { transform: translateY(0.25rem); }

/* X state (when menu open) — GSAP handles via data-menu-open attribute */

/* ── Back button (mobile sub-menu) ───────────────────────────── */
.mega-nav__back {
  display: none;
}

/* ── Dropdown wrapper — MUST EXIST (controller queries it) ───── */
.mega-nav__dropdown-wrapper {
  position: absolute;
  top: 100%;
  left: 0;
  right: 0;
  z-index: 999;
  pointer-events: none;
  overflow: hidden;
}

.mega-nav__dropdown-container {
  position: relative;
}

.mega-nav__dropdown-bg {
  position: absolute;
  inset: 0;
  background: #1a1a1a;
  border-radius: 0 0 0.875rem 0.875rem;
  transform-origin: top center;
  transform: scaleY(0);
}

/* ── Backdrop ────────────────────────────────────────────────── */
.mega-nav__backdrop {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 998;
  opacity: 0;
  pointer-events: none;
  backdrop-filter: blur(2px);
  -webkit-backdrop-filter: blur(2px);
}

/* ── Action list item ────────────────────────────────────────── */
.mega-nav__bar-action {
  display: flex;
  align-items: center;
}

/* ── Mobile: ≤991px ──────────────────────────────────────────── */
@media (max-width: 991px) {
  /* Show burger, hide nav lists */
  .mega-nav__bar-end {
    display: flex;
  }

  .mega-nav__bar-inner {
    /* Mobile: slide-over panel — hidden until open */
    display: none !important; /* replaced by mobile slide panel managed by JS */
  }

  /* Mobile slide-over panel using [data-mobile-nav] as the panel itself */
  [data-nav-list][data-mobile-nav] {
    display: flex !important;
    flex-direction: column;
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(22rem, 85vw);
    background: #131313;
    border-left: 1px solid rgba(255, 255, 255, 0.07);
    padding: 5rem 1.75rem 2.5rem;
    z-index: 999;
    overflow-y: auto;
    pointer-events: none;
    align-items: flex-start;
    gap: 2rem;
    /* Initial state: off-screen right */
    transform: translateX(110%);
  }

  /* Mobile: make both lists column */
  .mega-nav__bar-list {
    flex-direction: column;
    align-items: flex-start;
    width: 100%;
    gap: 0.25rem;
  }

  .mega-nav__bar-list.is--actions {
    flex-direction: column;
    align-items: flex-start;
    width: 100%;
    gap: 0.75rem;
    margin-top: auto;
  }

  [data-nav-list-item] {
    width: 100%;
  }

  /* Larger mobile link text */
  .mega-nav__bar-link {
    font-family: "Clash Display", sans-serif;
    font-size: 1.375rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    padding: 0.625em 0.5em;
    width: 100%;
  }

  /* Mobile locale switcher */
  .locale-switcher {
    background: rgba(255, 255, 255, 0.05);
    border-radius: 0.625rem;
    padding: 0.25rem;
  }

  .locale-btn {
    font-size: 0.8125rem;
    padding: 0.4375em 0.875em;
  }

  /* Mobile CTA full-width */
  .mega-nav__bar-cta {
    width: 100%;
    justify-content: center;
    padding: 0.875em 1.5em;
    font-size: 1rem;
  }
}

/* ── Mobile: ≤479px ──────────────────────────────────────────── */
@media (max-width: 479px) {
  .mega-nav__bar-logo-label {
    display: none;
  }
}

/* ── Reduced motion ──────────────────────────────────────────── */
@media (prefers-reduced-motion: reduce) {
  .mega-nav__bar-link,
  .mega-nav__bar-cta,
  .mega-nav__burger,
  .mega-nav__burger-line,
  .locale-btn,
  .mega-nav__backdrop,
  [data-nav-list][data-mobile-nav] {
    transition: none !important;
  }
}
</style>

<!-- ── Controller: initMegaNavDirectionalHover (GSAP-guarded) ──────────── -->
<script is:inline>
(function () {
  // Guard: init only once per page
  if (window.__megaNavInit) return;
  window.__megaNavInit = true;

  // ── Timing constants (osmo DUR pattern) ─────────────────────────────
  var DUR = {
    open:        0.45,
    close:       0.35,
    panelIn:     0.40,
    panelOut:    0.28,
    bgIn:        0.40,
    bgOut:       0.30,
    burgerOpen:  0.30,
    burgerClose: 0.25,
    mobileOpen:  0.40,
    mobileClose: 0.30,
    backdrop:    0.30,
    stagger:     0.04,
  };

  // ── State ────────────────────────────────────────────────────────────
  var state = {
    isOpen:       false,
    isMobileOpen: false,
    activePanel:  null,
    hoverTimeout: null,
    lastIndex:    -1,
  };

  // ── DOM refs ─────────────────────────────────────────────────────────
  var nav          = document.querySelector('[data-menu-wrap]');
  var mobileNav    = document.querySelector('[data-mobile-nav]');
  var backdrop     = document.querySelector('[data-menu-backdrop]');
  var burger       = document.querySelector('[data-burger-toggle]');
  var mobileBack   = document.querySelector('[data-mobile-back]');
  var dropWrapper  = document.querySelector('[data-dropdown-wrapper]');
  var dropContainer = document.querySelector('[data-dropdown-container]');
  var dropBg       = document.querySelector('[data-dropdown-bg]');
  var burgerLines  = {
    top: document.querySelector('[data-burger-line="top"]'),
    mid: document.querySelector('[data-burger-line="mid"]'),
    bot: document.querySelector('[data-burger-line="bot"]'),
  };

  // Toggles (data-dropdown-toggle) — empty in Phase 9 (no dropdowns)
  var toggles = document.querySelectorAll('[data-dropdown-toggle]');
  // Panels (data-nav-content) — empty in Phase 9
  var panels  = document.querySelectorAll('[data-nav-content]');

  if (!nav || !burger) return; // safety

  var prefersReducedMotion =
    window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ── GSAP lazy-loader ─────────────────────────────────────────────────
  function ensureGsap(cb) {
    if (window.gsap) { cb(); return; }
    var s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/gsap@3.15/dist/gsap.min.js';
    s.onload = cb;
    document.head.appendChild(s);
  }

  // ── Dropdown open/close (Phase 9: no-op — toggles array is empty) ───
  function openDropdown(panel) {
    if (!panel || !dropWrapper || !dropContainer || !dropBg) return;
    state.isOpen = true;
    state.activePanel = panel;
    dropWrapper.style.pointerEvents = 'auto';
    if (!prefersReducedMotion && window.gsap) {
      gsap.killTweensOf([dropBg, panel]);
      gsap.to(dropBg, { scaleY: 1, duration: DUR.bgIn, ease: 'power3.out' });
      gsap.fromTo(panel, { autoAlpha: 0, y: -8 }, { autoAlpha: 1, y: 0, duration: DUR.panelIn, ease: 'power3.out' });
    } else {
      if (dropBg) dropBg.style.transform = 'scaleY(1)';
      panel.style.opacity = '1';
      panel.style.visibility = 'visible';
    }
  }

  function closeDropdown() {
    if (!state.isOpen) return;
    var panel = state.activePanel;
    state.isOpen    = false;
    state.activePanel = null;
    if (!dropWrapper) return;
    if (!prefersReducedMotion && window.gsap) {
      gsap.killTweensOf([dropBg, panel]);
      if (panel) gsap.to(panel, { autoAlpha: 0, y: -4, duration: DUR.panelOut, ease: 'power2.in' });
      gsap.to(dropBg, {
        scaleY: 0,
        duration: DUR.bgOut,
        ease: 'power3.in',
        onComplete: function () {
          if (dropWrapper) dropWrapper.style.pointerEvents = 'none';
        },
      });
    } else {
      if (dropBg) dropBg.style.transform = 'scaleY(0)';
      if (panel) { panel.style.opacity = '0'; panel.style.visibility = 'hidden'; }
      if (dropWrapper) dropWrapper.style.pointerEvents = 'none';
    }
  }

  function switchPanel(newPanel, fromLeft) {
    if (!newPanel || newPanel === state.activePanel) return;
    var oldPanel = state.activePanel;
    state.activePanel = newPanel;
    if (!prefersReducedMotion && window.gsap) {
      if (oldPanel) gsap.to(oldPanel, { autoAlpha: 0, duration: 0.15, ease: 'power1.in' });
      gsap.fromTo(
        newPanel,
        { autoAlpha: 0, x: fromLeft ? -12 : 12 },
        { autoAlpha: 1, x: 0, duration: DUR.panelIn, ease: 'power3.out' }
      );
    } else {
      if (oldPanel) { oldPanel.style.opacity = '0'; oldPanel.style.visibility = 'hidden'; }
      newPanel.style.opacity  = '1';
      newPanel.style.visibility = 'visible';
    }
  }

  // ── Hover intent (directional) — toggles is empty in Phase 9 ────────
  toggles.forEach(function (toggle, i) {
    var key     = toggle.getAttribute('data-dropdown-toggle');
    var panel   = key ? document.querySelector('[data-nav-content="' + key + '"]') : null;

    toggle.addEventListener('mouseenter', function () {
      clearTimeout(state.hoverTimeout);
      var fromLeft = i < state.lastIndex;
      state.lastIndex = i;
      if (!panel) return;
      if (state.isOpen && state.activePanel !== panel) {
        switchPanel(panel, fromLeft);
      } else if (!state.isOpen) {
        ensureGsap(function () { openDropdown(panel); });
      }
    });

    toggle.addEventListener('mouseleave', function () {
      state.hoverTimeout = setTimeout(function () {
        closeDropdown();
      }, 120);
    });
  });

  if (dropWrapper) {
    dropWrapper.addEventListener('mouseenter', function () {
      clearTimeout(state.hoverTimeout);
    });
    dropWrapper.addEventListener('mouseleave', function () {
      state.hoverTimeout = setTimeout(closeDropdown, 120);
    });
  }

  // ── Burger animation ─────────────────────────────────────────────────
  function animateBurgerOpen() {
    if (!window.gsap || prefersReducedMotion) return;
    var tl = gsap.timeline();
    tl.to(burgerLines.mid, { scaleX: 0, duration: DUR.burgerOpen * 0.4, ease: 'power2.in' })
      .to(burgerLines.top, { y: 0, rotation: 45, duration: DUR.burgerOpen * 0.6, ease: 'power3.out' }, '-=0.05')
      .to(burgerLines.bot, { y: 0, rotation: -45, duration: DUR.burgerOpen * 0.6, ease: 'power3.out' }, '<');
  }

  function animateBurgerClose() {
    if (!window.gsap || prefersReducedMotion) return;
    var tl = gsap.timeline();
    tl.to([burgerLines.top, burgerLines.bot], { rotation: 0, duration: DUR.burgerClose * 0.6, ease: 'power3.out' })
      .to(burgerLines.top, { y: '-0.25rem', duration: DUR.burgerClose * 0.5, ease: 'power2.out' }, '-=0.1')
      .to(burgerLines.bot, { y: '0.25rem',  duration: DUR.burgerClose * 0.5, ease: 'power2.out' }, '<')
      .to(burgerLines.mid, { scaleX: 1, duration: DUR.burgerClose * 0.4, ease: 'power2.out' }, '-=0.1');
  }

  // ── Mobile menu open/close ───────────────────────────────────────────
  function openMobile() {
    state.isMobileOpen = true;
    nav.setAttribute('data-menu-open', 'true');
    burger.setAttribute('aria-expanded', 'true');

    if (mobileNav) {
      mobileNav.style.pointerEvents = 'auto';
      if (!prefersReducedMotion && window.gsap) {
        gsap.killTweensOf(mobileNav);
        gsap.to(mobileNav, { x: '0%', duration: DUR.mobileOpen, ease: 'power3.out' });

        // Stagger in the list items
        var items = mobileNav.querySelectorAll('[data-nav-list-item]');
        gsap.fromTo(
          items,
          { autoAlpha: 0, x: 20 },
          { autoAlpha: 1, x: 0, duration: 0.35, ease: 'power3.out', stagger: DUR.stagger, delay: 0.1 }
        );
      } else {
        mobileNav.style.transform = 'translateX(0%)';
      }
    }

    if (backdrop && !prefersReducedMotion && window.gsap) {
      backdrop.style.pointerEvents = 'auto';
      gsap.killTweensOf(backdrop);
      gsap.to(backdrop, { opacity: 1, duration: DUR.backdrop, ease: 'power2.out' });
    } else if (backdrop) {
      backdrop.style.opacity = '1';
      backdrop.style.pointerEvents = 'auto';
    }

    document.body.style.overflow = 'hidden';
    animateBurgerOpen();
  }

  function closeMobile() {
    state.isMobileOpen = false;
    nav.setAttribute('data-menu-open', 'false');
    burger.setAttribute('aria-expanded', 'false');

    if (mobileNav) {
      mobileNav.style.pointerEvents = 'none';
      if (!prefersReducedMotion && window.gsap) {
        gsap.killTweensOf(mobileNav);
        gsap.to(mobileNav, { x: '110%', duration: DUR.mobileClose, ease: 'power3.in' });
      } else {
        mobileNav.style.transform = 'translateX(110%)';
      }
    }

    if (backdrop && !prefersReducedMotion && window.gsap) {
      gsap.killTweensOf(backdrop);
      gsap.to(backdrop, {
        opacity: 0,
        duration: DUR.backdrop,
        ease: 'power2.in',
        onComplete: function () { if (backdrop) backdrop.style.pointerEvents = 'none'; },
      });
    } else if (backdrop) {
      backdrop.style.opacity = '0';
      backdrop.style.pointerEvents = 'none';
    }

    document.body.style.overflow = '';
    animateBurgerClose();
  }

  // ── Burger click ─────────────────────────────────────────────────────
  burger.addEventListener('click', function () {
    ensureGsap(function () {
      if (state.isMobileOpen) { closeMobile(); } else { openMobile(); }
    });
  });

  // ── Backdrop click ───────────────────────────────────────────────────
  if (backdrop) {
    backdrop.addEventListener('click', function () {
      if (state.isMobileOpen) closeMobile();
      if (state.isOpen) closeDropdown();
    });
  }

  // ── ESC key ──────────────────────────────────────────────────────────
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') {
      if (state.isMobileOpen) closeMobile();
      if (state.isOpen) closeDropdown();
    }
  });

  // ── Resize handler ───────────────────────────────────────────────────
  var resizeTimer;
  window.addEventListener('resize', function () {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function () {
      if (window.innerWidth > 991 && state.isMobileOpen) {
        closeMobile();
      }
    }, 150);
  });

  // ── Mobile back button ───────────────────────────────────────────────
  if (mobileBack) {
    mobileBack.addEventListener('click', function () {
      // Phase 9: no sub-panels, so back just closes the mobile menu
      closeMobile();
    });
  }

  // ── Locale switcher ──────────────────────────────────────────────────
  document.querySelectorAll('.locale-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var href = btn.getAttribute('data-href');
      if (href && !btn.disabled) window.location.href = href;
    });
  });

})(); // IIFE — runs immediately after DOM is parsed (is:inline is synchronous)
</script>
