---
/**
 * MegaNav — osmo.supply "mega-nav directional hover" adapted for nestorsegura.
 *
 * Implementation notes:
 * - Pure Astro component + <script is:inline> (NOT a React island per CONTEXT.md)
 * - GSAP loaded lazily from CDN if not already present (same pattern as StackingCards.astro)
 * - Locale switcher hrefs are pre-computed at build time (data-href attributes)
 * - data-dropdown-toggle hooks preserved on nav links even though panels are stripped
 *   (allows future mega-dropdown re-enable without HTML rewrite — per CONTEXT.md deferred)
 * - Brand: Jibemates purple (OKLCH hue 290) replaces osmo #6840ff
 * - Fonts: Clash Display (headings/links), Chivo (body/meta)
 */

interface Props {
  locale: 'de' | 'en' | 'es';
  navItems: Array<{ href: string; label: string }>;
  ctaLabel: string;
  ctaHref: string;
  localeUrls: Record<'de' | 'en' | 'es', string>;
}

const { locale, navItems, ctaLabel, ctaHref, localeUrls } = Astro.props;
const locales = ['de', 'en', 'es'] as const;
---

<nav class="mega-nav" data-menu-wrap aria-label="Main navigation">
  <!-- ── Desktop bar ────────────────────────────────────────────── -->
  <div class="mega-nav__bar">
    <!-- Logo / Brand -->
    <div class="mega-nav__bar-start">
      <a href={localeUrls[locale]} class="mega-nav__logo" aria-label="Homepage">
        <span class="mega-nav__logo-text">NS</span>
        <span class="mega-nav__logo-label">Real Estate Strategy</span>
      </a>
    </div>

    <!-- Desktop links (data-dropdown-toggle preserved for future dropdowns) -->
    <nav class="mega-nav__bar-nav" aria-label="Primary links">
      {navItems.map((item) => (
        <div class="mega-nav__link-wrap" data-dropdown-toggle>
          <a href={item.href} class="mega-nav__link">
            {item.label}
          </a>
        </div>
      ))}
    </nav>

    <!-- Bar end: locale switcher + CTA + burger -->
    <div class="mega-nav__bar-end">
      <!-- Locale segmented control -->
      <div class="locale-switcher" role="group" aria-label="Language">
        {locales.map((l) => (
          <button
            class={`locale-btn${l === locale ? ' is-active' : ''}`}
            data-href={localeUrls[l]}
            data-locale={l}
            aria-label={`Switch to ${l.toUpperCase()}`}
            aria-current={l === locale ? 'true' : undefined}
            disabled={l === locale ? true : undefined}
          >
            {l.toUpperCase()}
          </button>
        ))}
      </div>

      <!-- CTA -->
      <a
        href={ctaHref}
        class="mega-nav__cta"
        target="_blank"
        rel="noopener noreferrer"
      >
        {ctaLabel}
      </a>

      <!-- Burger (mobile only) -->
      <button
        data-burger-toggle
        class="mega-nav__burger"
        aria-label="Menu"
        aria-expanded="false"
        aria-controls="mega-nav-drawer"
      >
        <span class="mega-nav__burger-line"></span>
        <span class="mega-nav__burger-line"></span>
      </button>
    </div>
  </div>

  <!-- ── Mobile drawer ─────────────────────────────────────────── -->
  <div
    id="mega-nav-drawer"
    data-nav-content
    class="mega-nav__drawer"
    aria-hidden="true"
  >
    <div class="mega-nav__drawer-inner">
      <!-- Mobile nav links (data-dropdown-toggle preserved) -->
      <nav class="mega-nav__drawer-nav" aria-label="Mobile primary links">
        {navItems.map((item) => (
          <div class="mega-nav__link-wrap" data-dropdown-toggle>
            <a href={item.href} class="mega-nav__drawer-link">
              {item.label}
            </a>
          </div>
        ))}
      </nav>

      <!-- Mobile locale switcher -->
      <div class="locale-switcher locale-switcher--mobile" role="group" aria-label="Language">
        {locales.map((l) => (
          <button
            class={`locale-btn${l === locale ? ' is-active' : ''}`}
            data-href={localeUrls[l]}
            data-locale={l}
            aria-label={`Switch to ${l.toUpperCase()}`}
            aria-current={l === locale ? 'true' : undefined}
            disabled={l === locale ? true : undefined}
          >
            {l.toUpperCase()}
          </button>
        ))}
      </div>

      <!-- Mobile CTA -->
      <a
        href={ctaHref}
        class="mega-nav__cta mega-nav__cta--mobile"
        target="_blank"
        rel="noopener noreferrer"
      >
        {ctaLabel}
      </a>
    </div>
  </div>

  <!-- Backdrop (closes drawer on click) -->
  <div data-menu-backdrop class="mega-nav__backdrop" aria-hidden="true"></div>
</nav>

<!-- ── Styles ─────────────────────────────────────────────────────── -->
<style is:global>
/* ================================================================
   MEGA-NAV — osmo.supply "mega-nav directional hover" restyled
   for nestorsegura / Real Estate Strategy
   Brand: Jibemates purple (OKLCH hue 290), Clash Display, Chivo
   ================================================================ */

/* ── Reset / tokens ──────────────────────────────────────────── */
.mega-nav *,
.mega-nav *::before,
.mega-nav *::after {
  box-sizing: border-box;
}

/* ── Outer wrapper ───────────────────────────────────────────── */
.mega-nav {
  position: fixed;
  top: 1.25em;
  left: 0;
  right: 0;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  pointer-events: none; /* children re-enable pointer-events */
}

/* ── Bar ─────────────────────────────────────────────────────── */
.mega-nav__bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  margin: 0 1.25em;
  padding: 0.625em 1.25em;
  background: rgba(19, 19, 19, 0.92);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-radius: 0.875rem;
  border: 1px solid rgba(255, 255, 255, 0.07);
  pointer-events: auto;
}

/* ── Bar start — logo ────────────────────────────────────────── */
.mega-nav__bar-start {
  flex-shrink: 0;
}

.mega-nav__logo {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  text-decoration: none;
  color: #efeeec;
}

.mega-nav__logo-text {
  font-family: var(--font-heading, 'Clash Display', sans-serif);
  font-weight: 700;
  font-size: 1.25rem;
  color: oklch(0.58 0.20 290); /* primary-500 */
  letter-spacing: -0.02em;
  line-height: 1;
}

.mega-nav__logo-label {
  font-family: var(--font-body, 'Chivo', sans-serif);
  font-size: 0.75rem;
  font-weight: 400;
  color: rgba(239, 238, 236, 0.55);
  letter-spacing: 0.02em;
  white-space: nowrap;
}

/* ── Bar nav — desktop links ─────────────────────────────────── */
.mega-nav__bar-nav {
  display: flex;
  align-items: center;
  gap: 0.25rem;
  flex: 1;
  justify-content: center;
}

.mega-nav__link-wrap {
  position: relative;
}

.mega-nav__link {
  display: inline-flex;
  align-items: center;
  padding: 0.5em 0.875em;
  font-family: var(--font-body, 'Chivo', sans-serif);
  font-size: 0.9375rem;
  font-weight: 500;
  color: rgba(239, 238, 236, 0.80);
  text-decoration: none;
  border-radius: 0.5rem;
  transition: color 0.18s ease, background-color 0.18s ease;
  white-space: nowrap;
}

.mega-nav__link:hover {
  color: #efeeec;
  background-color: rgba(255, 255, 255, 0.06);
}

/* ── Bar end ─────────────────────────────────────────────────── */
.mega-nav__bar-end {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex-shrink: 0;
}

/* ── Locale switcher ─────────────────────────────────────────── */
.locale-switcher {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 0.5rem;
  padding: 0.1875rem;
  gap: 0.125rem;
}

.locale-btn {
  font-family: var(--font-body, 'Chivo', sans-serif);
  font-size: 0.6875rem;
  font-weight: 600;
  letter-spacing: 0.05em;
  color: rgba(239, 238, 236, 0.55);
  background: transparent;
  border: none;
  border-radius: 0.3125rem;
  padding: 0.3125em 0.5625em;
  cursor: pointer;
  transition: background-color 0.18s ease, color 0.18s ease;
  line-height: 1;
}

.locale-btn:hover:not(:disabled) {
  color: #efeeec;
  background-color: rgba(255, 255, 255, 0.08);
}

.locale-btn.is-active {
  background-color: oklch(0.58 0.20 290); /* primary-500 */
  color: #fff;
  cursor: default;
}

/* ── CTA button ──────────────────────────────────────────────── */
.mega-nav__cta {
  display: inline-flex;
  align-items: center;
  padding: 0.5625em 1.125em;
  font-family: var(--font-heading, 'Clash Display', sans-serif);
  font-size: 0.875rem;
  font-weight: 600;
  color: #fff;
  background: oklch(0.58 0.20 290); /* primary-500 */
  border-radius: 0.5rem;
  text-decoration: none;
  white-space: nowrap;
  transition: background-color 0.18s ease, transform 0.14s ease;
  letter-spacing: -0.01em;
}

.mega-nav__cta:hover {
  background: oklch(0.50 0.20 290); /* primary-600 */
  transform: translateY(-1px);
}

.mega-nav__cta:active {
  transform: translateY(0);
}

/* ── Burger ──────────────────────────────────────────────────── */
.mega-nav__burger {
  display: none;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 0.3125rem;
  width: 2.25rem;
  height: 2.25rem;
  background: rgba(255, 255, 255, 0.06);
  border: none;
  border-radius: 0.5rem;
  cursor: pointer;
  padding: 0;
  transition: background-color 0.18s ease;
}

.mega-nav__burger:hover {
  background: rgba(255, 255, 255, 0.10);
}

.mega-nav__burger-line {
  display: block;
  width: 1.125rem;
  height: 1.5px;
  background: rgba(239, 238, 236, 0.85);
  border-radius: 2px;
  transition: transform 0.25s ease, opacity 0.18s ease;
  transform-origin: center;
}

/* Burger open state — X */
.mega-nav[data-menu-open] .mega-nav__burger-line:first-child {
  transform: rotate(45deg) translate(0.21rem, 0.21rem);
}
.mega-nav[data-menu-open] .mega-nav__burger-line:last-child {
  transform: rotate(-45deg) translate(0.21rem, -0.21rem);
}

/* ── Mobile drawer ───────────────────────────────────────────── */
.mega-nav__drawer {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  width: min(22rem, 85vw);
  background: #131313;
  border-left: 1px solid rgba(255, 255, 255, 0.07);
  padding: 5rem 1.75rem 2.5rem;
  display: flex;
  flex-direction: column;
  transform: translateX(100%);
  will-change: transform;
  z-index: 999;
  pointer-events: none;
}

.mega-nav__drawer.is-open {
  pointer-events: auto;
}

.mega-nav__drawer-inner {
  display: flex;
  flex-direction: column;
  gap: 2rem;
  height: 100%;
}

.mega-nav__drawer-nav {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.mega-nav__drawer-link {
  display: block;
  padding: 0.75em 0.5em;
  font-family: var(--font-heading, 'Clash Display', sans-serif);
  font-size: 1.5rem;
  font-weight: 600;
  color: rgba(239, 238, 236, 0.80);
  text-decoration: none;
  border-radius: 0.375rem;
  letter-spacing: -0.02em;
  transition: color 0.18s ease, background-color 0.18s ease;
}

.mega-nav__drawer-link:hover {
  color: #efeeec;
  background-color: rgba(255, 255, 255, 0.04);
}

.locale-switcher--mobile {
  background: rgba(255, 255, 255, 0.04);
  border-radius: 0.625rem;
  padding: 0.25rem;
  width: fit-content;
}

.locale-switcher--mobile .locale-btn {
  font-size: 0.8125rem;
  padding: 0.4375em 0.875em;
}

.mega-nav__cta--mobile {
  display: block;
  text-align: center;
  padding: 0.875em 1.5em;
  font-size: 1rem;
  margin-top: auto;
}

/* ── Backdrop ────────────────────────────────────────────────── */
.mega-nav__backdrop {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 998;
  opacity: 0;
  pointer-events: none;
  backdrop-filter: blur(2px);
  -webkit-backdrop-filter: blur(2px);
  transition: opacity 0.3s ease;
}

/* ── Mobile breakpoint ───────────────────────────────────────── */
@media (max-width: 61.9375rem) { /* 991px */
  .mega-nav__bar-nav {
    display: none;
  }

  .mega-nav__burger {
    display: flex;
  }

  /* Hide desktop locale switcher on mobile (it's in the drawer) */
  .mega-nav__bar-end .locale-switcher:not(.locale-switcher--mobile) {
    display: none;
  }
}

@media (min-width: 62rem) { /* 992px+ */
  /* Hide the desktop CTA on small bar if space is tight — keep full label */
  .mega-nav__drawer {
    /* On desktop the drawer is never shown; hide fully */
    display: none !important;
  }
  .mega-nav__backdrop {
    display: none !important;
  }
}

/* ── Reduced motion ──────────────────────────────────────────── */
@media (prefers-reduced-motion: reduce) {
  .mega-nav__drawer,
  .mega-nav__backdrop,
  .mega-nav__burger-line,
  .mega-nav__link,
  .mega-nav__cta,
  .locale-btn {
    transition: none !important;
  }
}
</style>

<!-- ── Controller script ──────────────────────────────────────────── -->
<script is:inline>
(function () {
  // Guard: init once per page load
  if (window.__megaNavInit) return;
  window.__megaNavInit = true;

  // ── GSAP lazy-loader (same pattern as StackingCards.astro) ───────
  function loadScript(src, onload) {
    var s = document.createElement('script');
    s.src = src;
    s.onload = onload;
    document.head.appendChild(s);
  }

  function ensureGsap(cb) {
    if (window.gsap) {
      cb();
      return;
    }
    loadScript(
      'https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js',
      cb
    );
  }

  // ── Main init ────────────────────────────────────────────────────
  function initMegaNav() {
    var nav = document.querySelector('[data-menu-wrap]');
    var drawer = document.querySelector('[data-nav-content]');
    var backdrop = document.querySelector('[data-menu-backdrop]');
    var burger = document.querySelector('[data-burger-toggle]');

    if (!nav || !drawer || !burger) return;

    var isOpen = false;
    var prefersReducedMotion =
      window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ── Locale switcher (all buttons — desktop + mobile) ──────────
    document.querySelectorAll('.locale-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var href = btn.getAttribute('data-href');
        if (href) {
          window.location.href = href;
        }
      });
    });

    // ── Directional hover tracking (data-dropdown-toggle hooks) ───
    // Even though panels are stripped for Phase 9, we preserve the
    // directional-hover logic so future mega-dropdown re-enable is trivial.
    var linkWraps = document.querySelectorAll('[data-dropdown-toggle]');
    var lastHoveredIndex = -1;

    linkWraps.forEach(function (wrap, i) {
      wrap.addEventListener('mouseenter', function () {
        var direction = i > lastHoveredIndex ? 'right' : 'left';
        wrap.setAttribute('data-direction', direction);
        lastHoveredIndex = i;
      });
    });

    // ── Drawer open/close ─────────────────────────────────────────
    function openDrawer() {
      isOpen = true;
      nav.setAttribute('data-menu-open', '');
      burger.setAttribute('aria-expanded', 'true');
      drawer.setAttribute('aria-hidden', 'false');
      drawer.classList.add('is-open');

      if (!prefersReducedMotion && window.gsap) {
        gsap.killTweensOf([drawer, backdrop]);
        gsap.to(drawer, { x: '0%', duration: 0.38, ease: 'power3.out' });
        if (backdrop) {
          backdrop.style.pointerEvents = 'auto';
          gsap.to(backdrop, { opacity: 1, duration: 0.3, ease: 'power2.out' });
        }
      } else {
        drawer.style.transform = 'translateX(0%)';
        if (backdrop) {
          backdrop.style.opacity = '1';
          backdrop.style.pointerEvents = 'auto';
        }
      }

      document.body.style.overflow = 'hidden';
    }

    function closeDrawer() {
      isOpen = false;
      nav.removeAttribute('data-menu-open');
      burger.setAttribute('aria-expanded', 'false');
      drawer.setAttribute('aria-hidden', 'true');
      drawer.classList.remove('is-open');

      if (!prefersReducedMotion && window.gsap) {
        gsap.killTweensOf([drawer, backdrop]);
        gsap.to(drawer, { x: '100%', duration: 0.32, ease: 'power3.in' });
        if (backdrop) {
          gsap.to(backdrop, {
            opacity: 0,
            duration: 0.25,
            ease: 'power2.in',
            onComplete: function () {
              backdrop.style.pointerEvents = 'none';
            },
          });
        }
      } else {
        drawer.style.transform = 'translateX(100%)';
        if (backdrop) {
          backdrop.style.opacity = '0';
          backdrop.style.pointerEvents = 'none';
        }
      }

      document.body.style.overflow = '';
    }

    burger.addEventListener('click', function () {
      if (isOpen) {
        closeDrawer();
      } else {
        ensureGsap(openDrawer);
      }
    });

    if (backdrop) {
      backdrop.addEventListener('click', closeDrawer);
    }

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && isOpen) {
        closeDrawer();
      }
    });
  }

  // ── Boot ─────────────────────────────────────────────────────────
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMegaNav);
  } else {
    initMegaNav();
  }
})();
</script>
