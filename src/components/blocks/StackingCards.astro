---
/**
 * StackingCards — osmo.supply stacking sticky cards (bounce).
 *
 * Osmo DOM/CSS/JS preserved verbatim. Only brand swaps:
 *   - is--green uses our brand-muted tone (was osmo #b1ae91 — kept as fallback)
 *   - is--dark uses our brand-dark (#131313)
 *
 * Consumers keep current markup pattern:
 *   <StackingCards variant="narrow|wide" desktopRotate="..." desktopX="..." desktopY="...">
 *     <div data-slot-parent data-stacking-card class="cards-stack__item">
 *       <div data-stacking-card-target class="cards-stack-card">...</div>
 *     </div>
 *   </StackingCards>
 */

interface Props {
  variant: 'narrow' | 'wide'
  desktopRotate?: string
  desktopX?: string
  desktopY?: string
  tabletRotate?: string
  tabletX?: string
  tabletY?: string
  mobileRotate?: string
  mobileX?: string
  mobileY?: string
}

const {
  variant,
  desktopRotate,
  desktopX,
  desktopY,
  tabletRotate,
  tabletX,
  tabletY,
  mobileRotate,
  mobileX,
  mobileY,
} = Astro.props

const sectionAttrs: Record<string, string> = {
  'data-stacking-cards-init': '',
  'data-stacking-cards-desktop': 'true',
  'data-stacking-cards-tablet': 'true',
  'data-stacking-cards-mobile': 'true',
}

if (desktopRotate) sectionAttrs['data-stacking-cards-desktop-rotate'] = desktopRotate
if (desktopX)      sectionAttrs['data-stacking-cards-desktop-x']      = desktopX
if (desktopY)      sectionAttrs['data-stacking-cards-desktop-y']      = desktopY
if (tabletRotate)  sectionAttrs['data-stacking-cards-tablet-rotate']  = tabletRotate
if (tabletX)       sectionAttrs['data-stacking-cards-tablet-x']       = tabletX
if (tabletY)       sectionAttrs['data-stacking-cards-tablet-y']       = tabletY
if (mobileRotate)  sectionAttrs['data-stacking-cards-mobile-rotate']  = mobileRotate
if (mobileX)       sectionAttrs['data-stacking-cards-mobile-x']       = mobileX
if (mobileY)       sectionAttrs['data-stacking-cards-mobile-y']       = mobileY
---

<section {...sectionAttrs} class="cards-stack">
  <div class="container">
    <div class="cards-stack__collection">
      <div data-stacking-card-stack class="cards-stack__list">
        <slot />
      </div>
    </div>
  </div>
</section>

<style is:global>
/* ============================================================
   OSMO SUPPLY — Stacking Sticky Cards (Bounce) — VERBATIM
   Only palette adjusted for brand; structure untouched.
   ============================================================ */

.cards-stack {
  padding-top: 15dvh;
  padding-bottom: 15dvh;
}

.cards-stack .container {
  max-width: 90em;
  margin-left: auto;
  margin-right: auto;
  padding-left: 2em;
  padding-right: 2em;
}

.cards-stack__list {
  grid-column-gap: 5em;
  grid-row-gap: 5em;
  flex-flow: column;
  justify-content: center;
  align-items: center;
  width: 100%;
  display: flex;
}

.cards-stack__item {
  flex: none;
  width: 100%;
  max-width: 25em;
  position: sticky;
  top: 5em;
}

.cards-stack__item.is--wide {
  max-width: 60em;
}

.cards-stack-card {
  aspect-ratio: 2 / 3;
  background-color: #fff;
  border-radius: 2em;
  flex-flow: column;
  justify-content: space-between;
  width: 100%;
  padding: 2.5em;
  display: flex;
}

.cards-stack-card.is--green {
  color: #fff;
  background-color: oklch(0.50 0.20 290);
}

.cards-stack-card.is--dark {
  color: #fff;
  background-color: #131313;
}

.cards-stack-card.is--lilac {
  color: #1d1d1f;
  background-color: #ddd7f1;
}

.cards-stack-card.is--teal {
  color: #0a3a40;
  background-color: #2ecfe0;
}

.cards-stack-card.is--wide {
  aspect-ratio: 5 / 3;
}

.cards-stack-card__number {
  font-size: 6.75em;
  font-weight: 500;
  line-height: .95;
}

.cards-stack-card__h {
  letter-spacing: -.04em;
  margin-top: 0;
  margin-bottom: 0;
  font-size: 3.375em;
  font-weight: 600;
  line-height: .95;
}

.cards-stack-card__h.is--l {
  font-size: 4.5em;
}

.cards-stack-card__services {
  flex-flow: column;
  justify-content: flex-end;
  min-height: 11em;
  display: flex;
}

.cards-stack-card__services-p {
  letter-spacing: -.01em;
  margin-bottom: 0;
  font-size: 1.125em;
  font-weight: 500;
  line-height: 1.4;
}

@media screen and (max-width: 991px) {
  .cards-stack-card.is--wide {
    aspect-ratio: 5 / 4;
  }
}

@media screen and (max-width: 767px) {
  .cards-stack__item.is--wide {
    max-width: 25em;
  }

  .cards-stack-card {
    font-size: .8em;
  }

  .cards-stack-card.is--wide {
    aspect-ratio: 2 / 3;
  }

  .cards-stack-card__h.is--l {
    font-size: 3.375em;
  }
}
</style>

<!-- GSAP + ScrollTrigger (CDN) + osmo stacking sticky cards bounce -->
<script is:inline>
(function () {
  if (window._cardsStackInitialized) return;
  window._cardsStackInitialized = true;

  function loadScript(src, cb) {
    var s = document.createElement('script');
    s.src = src;
    s.onload = cb;
    document.head.appendChild(s);
  }

  function boot() {
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initStackingStickyCardsBounce);
    } else {
      initStackingStickyCardsBounce();
    }
  }

  function ensureGsap(cb) {
    if (window.gsap && window.ScrollTrigger) { cb(); return; }
    if (window.gsap) {
      loadScript('https://cdn.jsdelivr.net/npm/gsap@3.15/dist/ScrollTrigger.min.js', cb);
      return;
    }
    loadScript('https://cdn.jsdelivr.net/npm/gsap@3.15/dist/gsap.min.js', function () {
      loadScript('https://cdn.jsdelivr.net/npm/gsap@3.15/dist/ScrollTrigger.min.js', cb);
    });
  }

  function initStackingStickyCardsBounce() {
    gsap.registerPlugin(ScrollTrigger);

    var cardsSections = document.querySelectorAll('[data-stacking-cards-init]');

    var currentTier = getCurrentViewportTier();
    window.viewportTier = currentTier;

    ScrollTrigger.getAll().forEach(function (trigger) {
      cardsSections.forEach(function (section) {
        if (section.contains(trigger.trigger)) trigger.kill();
      });
    });

    cardsSections.forEach(function (section) {
      section.querySelectorAll('[data-stacking-card-target]').forEach(function (el) {
        gsap.killTweensOf(el);
        gsap.set(el, { clearProps: 'all' });
      });
    });

    cardsSections.forEach(function (section) {
      var tier = currentTier;

      var isEnabled = (tier === 'desktop' && section.dataset.stackingCardsDesktop === 'true') ||
        (tier === 'tablet' && section.dataset.stackingCardsTablet === 'true') ||
        ((tier === 'mobile-portrait' || tier === 'mobile-landscape') &&
          section.dataset.stackingCardsMobile === 'true');

      if (!isEnabled) return;

      var cards = Array.from(section.querySelectorAll('[data-stacking-card]'));
      if (!cards.length) return;

      var stickyTop = parseFloat(getComputedStyle(cards[0]).top) || 0;

      var rotateValues = (function () {
        if (tier === 'desktop') return parseRotateValues(section, 'data-stacking-cards-desktop-rotate');
        if (tier === 'tablet') return parseRotateValues(section, 'data-stacking-cards-tablet-rotate');
        return parseRotateValues(section, 'data-stacking-cards-mobile-rotate');
      })();

      var xValues = (function () {
        if (tier === 'desktop') return parseAxisValues(section, 'data-stacking-cards-desktop-x');
        if (tier === 'tablet') return parseAxisValues(section, 'data-stacking-cards-tablet-x');
        return parseAxisValues(section, 'data-stacking-cards-mobile-x');
      })();

      var yValues = (function () {
        if (tier === 'desktop') return parseAxisValues(section, 'data-stacking-cards-desktop-y');
        if (tier === 'tablet') return parseAxisValues(section, 'data-stacking-cards-tablet-y');
        return parseAxisValues(section, 'data-stacking-cards-mobile-y');
      })();

      cards.forEach(function (card, index) {
        var targetEl = card.querySelector('[data-stacking-card-target]');
        if (!targetEl) return;

        var rotate = rotateValues[index % rotateValues.length];
        var x = xValues[index % xValues.length];
        var y = yValues[index % yValues.length];

        gsap.set(targetEl, {
          rotate: 0,
          x: 0,
          y: 0,
          scale: 1,
          zIndex: cards.length - index
        });

        gsap.to(targetEl, {
          rotate: rotate,
          x: x,
          y: y,
          ease: 'power1.in',
          overwrite: 'auto',
          scrollTrigger: {
            id: 'stacking-rotate-' + index,
            trigger: card,
            start: 'top 75%',
            end: 'top-=' + stickyTop + ' top',
            scrub: true
          }
        });

        ScrollTrigger.create({
          id: 'stacking-bounce-' + index,
          trigger: card,
          start: 'top-=' + stickyTop + ' top',
          onEnter: function () { pulseElement(targetEl); }
        });
      });
    });

    ScrollTrigger.refresh();

    function parseRotateValues(section, attr) {
      var fallback = [0, 4, -4];
      var values = (section.getAttribute(attr) || '').split(',').map(function (val) { return parseFloat(val.trim()); });
      return values.length >= 1 && values.every(function (v) { return !isNaN(v); }) ? values : fallback;
    }

    function parseAxisValues(section, attr) {
      var raw = section.getAttribute(attr);
      if (!raw) return ['0em', '0em', '0em'];
      var values = raw.split(',').map(function (val) { return val.trim(); }).filter(function (val) { return val !== ''; });
      return values.length ? values : ['0em', '0em', '0em'];
    }

    if (!window._hasStackingResizeListener) {
      var last = getCurrentViewportTier();

      window.addEventListener('resize', debounceOnWidthChange(function () {
        var next = getCurrentViewportTier();

        if (last !== next) {
          ScrollTrigger.getAll().forEach(function (t) {
            if (t.vars && t.vars.id && t.vars.id.indexOf('stacking') === 0) t.kill();
          });

          cardsSections.forEach(function (section) {
            section.querySelectorAll('[data-stacking-card-target]').forEach(function (el) {
              gsap.killTweensOf(el);
              gsap.set(el, { clearProps: 'all' });
            });
          });

          initStackingStickyCardsBounce();
        }

        last = next;
        window.viewportTier = next;
      }, 250));

      window._hasStackingResizeListener = true;
    }

    function getCurrentViewportTier() {
      var width = window.innerWidth;
      if (width <= 479) return 'mobile-portrait';
      if (width <= 767) return 'mobile-landscape';
      if (width <= 991) return 'tablet';
      return 'desktop';
    }

    function pulseElement(targetEl) {
      var width = targetEl.offsetWidth;
      var height = targetEl.offsetHeight;
      var fontSize = parseFloat(getComputedStyle(targetEl).fontSize);
      var stretchPx = 1.5 * fontSize;
      var targetScaleX = (width + stretchPx) / width;
      var targetScaleY = (height - stretchPx * 0.33) / height;

      var tl = gsap.timeline();
      tl.to(targetEl, {
        scaleX: targetScaleX,
        scaleY: targetScaleY,
        duration: 0.1,
        ease: 'power1.out'
      }).to(targetEl, {
        scaleX: 1,
        scaleY: 1,
        duration: 1,
        ease: 'elastic.out(1, 0.3)'
      });
    }
  }

  function debounceOnWidthChange(fn, ms) {
    var last = innerWidth;
    var timer;
    return function () {
      var args = arguments;
      var ctx = this;
      clearTimeout(timer);
      timer = setTimeout(function () {
        if (innerWidth !== last) {
          last = innerWidth;
          fn.apply(ctx, args);
        }
      }, ms);
    };
  }

  ensureGsap(boot);
})();
</script>
