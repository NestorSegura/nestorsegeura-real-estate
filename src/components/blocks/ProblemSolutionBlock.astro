---
import type { Locale } from '../../i18n/utils'
import StackingCards from './StackingCards.astro'

interface ProblemItem {
  _key?: string
  number?: string
  headline?: string
  description?: string
}

interface Props {
  locale: Locale
  title?: string
  problems?: ProblemItem[]
  colorScheme?: 'light' | 'dark'
  [key: string]: unknown
}

const { title, problems = [], colorScheme = 'light' } = Astro.props

const isDark = colorScheme === 'dark'
const sectionClass = isDark ? 'bg-primary-900 text-white' : 'bg-white text-gray-900'
const titleClass   = isDark ? 'text-white' : 'text-gray-900'
const descClass    = isDark ? 'text-primary-200' : 'text-gray-600'
const cardBg       = isDark ? 'bg-primary-800/50 border border-primary-700/40' : 'bg-white'
---

<section id="problem" class={sectionClass}>
  <div class="max-w-[72em] mx-auto px-[1.5em] pt-[4em] md:pt-[6em]">
    {title && (
      <h2 class={`text-[1.875em] md:text-[2.25em] font-bold mb-[2em] ${titleClass}`}>
        {title}
      </h2>
    )}
  </div>

  {problems.length > 0 && (
    <StackingCards
      variant="narrow"
      desktopRotate="-5, 2, 6"
      desktopX="-13.75em, 0em, 13em"
      desktopY="2.125em, 0em, 4.5em"
    >
      {problems.map((problem) => (
        <div data-stacking-card class="cards-stack__item">
          <div
            data-stacking-card-target
            class={`cards-stack-card ${cardBg}`}
          >
            <span
              class="card-number text-primary-300"
              aria-hidden="true"
            >
              {problem.number ?? ''}
            </span>
            {problem.headline && (
              <h3 class={`text-[1.25em] font-bold mt-[1em] mb-[0.5em] ${titleClass}`}>{problem.headline}</h3>
            )}
            {problem.description && (
              <p class={`text-[1em] leading-relaxed ${descClass}`}>{problem.description}</p>
            )}
          </div>
        </div>
      ))}
    </StackingCards>
  )}

  <div class="pb-[4em] md:pb-[6em]"></div>
</section>
