---
import type { Locale } from '../../i18n/utils'

interface ProblemItem {
  _key?: string
  number?: string
  headline?: string
  description?: string
}

interface Props {
  locale: Locale
  title?: string
  problems?: ProblemItem[]
  colorScheme?: 'light' | 'dark'
  [key: string]: unknown
}

const { title, problems = [], colorScheme = 'light' } = Astro.props

const isDark = colorScheme === 'dark'
const sectionClass = isDark ? 'bg-primary-900 text-white' : 'bg-white text-gray-900'
const cardClass = isDark
  ? 'bg-primary-800/50 border-primary-700/40'
  : 'bg-gray-50 border-gray-100'
const titleClass = isDark ? 'text-white' : 'text-gray-900'
const descClass = isDark ? 'text-primary-200' : 'text-gray-600'
---

<section id="problem" class={`${sectionClass} py-16 md:py-24 px-6`}>
  <div class="max-w-6xl mx-auto">
    {title && (
      <h2 class={`text-3xl md:text-4xl font-bold mb-12 ${titleClass}`}>
        {title}
      </h2>
    )}

    {problems.length > 0 && (
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        {problems.map((problem) => (
          <div class={`flex flex-col gap-4 p-8 rounded-2xl border ${cardClass}`}>
            <span
              class="text-7xl font-black leading-none tabular-nums select-none text-primary-300"
              aria-hidden="true"
            >
              {problem.number ?? ''}
            </span>
            {problem.headline && (
              <h3 class={`text-xl font-bold ${titleClass}`}>{problem.headline}</h3>
            )}
            {problem.description && (
              <p class={`text-base leading-relaxed ${descClass}`}>{problem.description}</p>
            )}
          </div>
        ))}
      </div>
    )}
  </div>
</section>
