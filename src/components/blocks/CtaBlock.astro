---
import type { Locale } from '../../i18n/utils'
import Button from '../ui/Button.astro'

interface Props {
  locale: Locale
  headline?: string
  subtext?: string
  ctaLabel?: string
  ctaHref?: string
  variant?: string
  colorScheme?: 'light' | 'dark'
  [key: string]: unknown
}

const {
  headline,
  subtext,
  ctaLabel,
  ctaHref,
  colorScheme = 'dark',
} = Astro.props

const isDark = colorScheme === 'dark'
const sectionClass = isDark ? 'bg-primary-900 text-white' : 'bg-gray-50 text-gray-900'
const subtextClass = isDark ? 'text-white/80' : 'text-gray-600'
---

<section id="cta" class={`${sectionClass} py-[4em] md:py-[6em] px-[1.5em] text-center`}>
  <div class="max-w-[48em] mx-auto">
    {headline && (
      <h2 class="text-[1.875em] md:text-[2.25em] font-bold mb-[1.5em] leading-tight">
        {headline}
      </h2>
    )}

    {subtext && (
      <p class={`text-[1.125em] md:text-[1.25em] mb-[2.5em] leading-relaxed ${subtextClass}`}>
        {subtext}
      </p>
    )}

    {ctaHref && ctaLabel && (
      <Button href={ctaHref} label={ctaLabel} variant="filled" size="large" tone={isDark ? 'white' : 'primary'} />
    )}
  </div>
</section>
