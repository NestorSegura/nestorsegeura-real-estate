---
import type { Locale } from '../../i18n/utils'

interface FeatureItem {
  _key?: string
  icon?: string
  title?: string
  description?: string
}

interface Props {
  locale: Locale
  title?: string
  features?: FeatureItem[]
  colorScheme?: 'light' | 'dark'
  [key: string]: unknown
}

const { title, features = [], colorScheme = 'light' } = Astro.props

const isDark = colorScheme === 'dark'
const sectionClass = isDark ? 'bg-primary-900 text-white' : 'bg-gray-50 text-gray-900'
const cardClass = isDark
  ? 'bg-primary-800/50 border-primary-700/40 text-white'
  : 'bg-white border-gray-200 text-gray-900'
const descClass = isDark ? 'text-primary-200' : 'text-gray-600'
---

<section id="features" class={`${sectionClass} py-16 md:py-24 px-6`}>
  <div class="max-w-6xl mx-auto">
    {title && (
      <h2 class="text-3xl md:text-4xl font-bold mb-12 text-center">
        {title}
      </h2>
    )}

    {features.length > 0 && (
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {features.map((feature) => (
          <div class={`flex flex-col gap-4 p-8 rounded-2xl border ${cardClass}`}>
            {feature.icon && (
              <span class="text-3xl leading-none" aria-hidden="true">{feature.icon}</span>
            )}
            {feature.title && (
              <h3 class="text-xl font-bold">{feature.title}</h3>
            )}
            {feature.description && (
              <p class={`text-base leading-relaxed ${descClass}`}>{feature.description}</p>
            )}
          </div>
        ))}
      </div>
    )}
  </div>
</section>
