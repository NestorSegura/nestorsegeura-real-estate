---
import type { Locale } from '../../i18n/utils'

interface ComparisonItem {
  _key?: string
  before?: string
  after?: string
}

interface ServiceItem {
  _key?: string
  title?: string
}

interface Props {
  locale: Locale
  headline?: string
  comparison?: ComparisonItem[]
  services?: ServiceItem[]
  ctaLabel?: string
  ctaHref?: string
  [key: string]: unknown
}

const { headline, comparison = [], services = [], ctaLabel, ctaHref } = Astro.props
---

<section id="offer" class="bg-gray-50 py-16 md:py-24 px-6">
  <div class="max-w-5xl mx-auto">
    {headline && (
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-12">
        {headline}
      </h2>
    )}

    {comparison.length > 0 && (
      <div class="mb-12 overflow-hidden rounded-2xl border border-gray-200 bg-white">
        <div class="grid grid-cols-2 divide-x divide-gray-200">
          <div class="bg-red-50 px-6 py-4 font-semibold text-red-700 text-sm uppercase tracking-wide">
            Vorher
          </div>
          <div class="bg-primary-50 px-6 py-4 font-semibold text-primary-700 text-sm uppercase tracking-wide">
            Nachher
          </div>
        </div>
        {comparison.map((item) => (
          <div class="grid grid-cols-2 divide-x divide-gray-200 border-t border-gray-200">
            <div class="px-6 py-4 flex items-center gap-3 text-gray-500">
              <span class="text-red-400 shrink-0" aria-hidden="true">✕</span>
              <span class="line-through text-sm">{item.before}</span>
            </div>
            <div class="px-6 py-4 flex items-center gap-3 text-gray-900">
              <span class="text-primary-600 shrink-0" aria-hidden="true">✓</span>
              <span class="text-sm font-medium">{item.after}</span>
            </div>
          </div>
        ))}
      </div>
    )}

    {services.length > 0 && (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-12">
        {services.map((service) => (
          <div class="flex items-center gap-3 p-5 rounded-xl bg-white border border-gray-200 shadow-sm">
            <span class="w-8 h-8 rounded-full bg-primary-700 flex items-center justify-center shrink-0" aria-hidden="true">
              <svg width="14" height="11" viewBox="0 0 14 11" fill="none" aria-hidden="true">
                <path d="M1.5 5.5l3.5 3.5 7.5-7.5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
            {service.title && (
              <span class="text-sm font-medium text-gray-900">{service.title}</span>
            )}
          </div>
        ))}
      </div>
    )}

    {ctaHref && ctaLabel && (
      <div class="text-center">
        <a
          href={ctaHref}
          class="inline-block bg-primary-700 hover:bg-primary-800 text-white font-semibold text-lg px-8 py-4 rounded-lg transition-all duration-200 hover:-translate-y-px"
        >
          {ctaLabel}
        </a>
      </div>
    )}
  </div>
</section>
