---
import type { Locale } from '../../i18n/utils'

interface Props {
  locale: Locale
  headline?: string
  ctaLabel?: string
  ctaHref?: string
  comparison?: unknown
  services?: unknown
  [key: string]: unknown
}

const { locale, headline, ctaLabel, ctaHref } = Astro.props

const copy = {
  de: {
    eyebrow: 'Die Strategie',
    defaultHeadline: 'Warum diese Methode bei Google UND bei ChatGPT funktioniert',
    pillars: [
      {
        number: '01',
        title: 'Entitäts-Konsistenz',
        lead: 'Google matcht keine Keywords mehr — Google matcht Entitäten.',
        body: 'Dein Google Business Profil, deine Website und deine Online-Präsenz müssen exakt dieselbe Geschichte erzählen. Jede Lücke zwischen dem, was im GBP steht, und dem, was die Website zeigt, kostet Vertrauen — bei Google und bei den KI-Modellen (ChatGPT, Perplexity, Gemini bewerten lokale Unternehmen nach demselben Muster).',
        illo: 'entity',
      },
      {
        number: '02',
        title: 'Die Kernstruktur',
        lead: 'Eine Seite pro Leistung. Eine Seite pro Stadtteil. Keine Ausnahmen.',
        body: 'Homepage zielt auf Primär-Kategorie und Stadt. Jede Dienstleistung bekommt eine eigene Seite, jeder Stadtteil ebenso. Die interne Verlinkung spiegelt die GBP-Hierarchie exakt. So baut Google Vertrauen auf, dass dein Unternehmen lokal und real ist.',
        illo: 'structure',
      },
      {
        number: '03',
        title: 'Lokale Inhalts-Tiefe',
        lead: 'Generische Inhalte ranken nicht lokal. Punkt.',
        body: 'Ein Makler in Hamburg muss über Altona und Eimsbüttel Preisdynamiken sprechen, über Altbau und Neubauten, über das Käuferprofil im konkreten Viertel. Inhalte, die lokale Begriffe, Marktbedingungen und Immobilientypen referenzieren — das ist der einzige Weg, lokal sichtbar zu werden.',
        illo: 'local',
      },
      {
        number: '04',
        title: 'KI-Sichtbarkeit',
        lead: 'Einmal bauen. Überall sichtbar.',
        body: 'Die Struktur, die bei Google rankt, macht dich für KI-Modelle auffindbar. Wenn jemand ChatGPT fragt „Bester Immobilienmakler in Hamburg-Altona", erscheinen die Makler mit konsistenten Entitäts-Signalen über Web, GBP und lokale Inhalte. Die Zukunft der lokalen Suche — und sie hat schon begonnen.',
        illo: 'ai',
      },
    ],
  },
  en: {
    eyebrow: 'The strategy',
    defaultHeadline: 'Why this method works on Google AND on ChatGPT',
    pillars: [
      {
        number: '01',
        title: 'Entity Consistency',
        lead: 'Google no longer matches keywords — it matches entities.',
        body: 'Your Google Business Profile, your website, and your online presence must tell the exact same story. Every gap between what your profile says and what your website shows costs trust — with Google, and with the AI models (ChatGPT, Perplexity, Gemini all evaluate local businesses the same way).',
        illo: 'entity',
      },
      {
        number: '02',
        title: 'The Core Structure',
        lead: 'One page per service. One page per area. No exceptions.',
        body: 'Homepage targets primary category and city. Each service gets its own page, each location likewise. Internal linking mirrors the GBP hierarchy exactly. This is how Google gains confidence that your business is legitimate and local.',
        illo: 'structure',
      },
      {
        number: '03',
        title: 'Local Content Depth',
        lead: 'Generic content does not rank locally. Full stop.',
        body: 'An agent in Hamburg should talk about Altona and Eimsbüttel price dynamics, Altbau and new-build specifics, the local buyer profile. Content that references specific neighborhoods, market conditions, and property types is the only way to become visible locally.',
        illo: 'local',
      },
      {
        number: '04',
        title: 'AI Visibility',
        lead: 'Build once. Visible everywhere.',
        body: 'The structure that ranks on Google makes you visible to AI models. When someone asks ChatGPT "best real estate agent in Hamburg Altona", the agents with consistent entity signals across web, GBP, and local content appear. This is the future of local search — and it has already started.',
        illo: 'ai',
      },
    ],
  },
  es: {
    eyebrow: 'La estrategia',
    defaultHeadline: 'Por qué este método funciona en Google Y en ChatGPT',
    pillars: [
      {
        number: '01',
        title: 'Consistencia de Entidad',
        lead: 'Google ya no empareja palabras clave — empareja entidades.',
        body: 'Tu perfil de Google Business, tu web y tu presencia online deben contar exactamente la misma historia. Cada hueco entre lo que dice tu perfil y lo que muestra tu web cuesta confianza — con Google, y con los modelos de IA (ChatGPT, Perplexity, Gemini evalúan los negocios locales igual).',
        illo: 'entity',
      },
      {
        number: '02',
        title: 'La Estructura Base',
        lead: 'Una página por servicio. Una página por zona. Sin excepciones.',
        body: 'La home apunta a categoría principal y ciudad. Cada servicio tiene su propia página, cada zona también. El enlazado interno refleja exactamente la jerarquía del GBP. Así Google gana confianza de que tu negocio es real y local.',
        illo: 'structure',
      },
      {
        number: '03',
        title: 'Profundidad Local del Contenido',
        lead: 'El contenido genérico no posiciona localmente. Punto.',
        body: 'Un agente en Madrid debe hablar de Salamanca y Chamberí, de pisos antiguos y obra nueva, del perfil del comprador del barrio. Contenido que referencia barrios concretos, condiciones de mercado y tipos de vivienda — la única vía para ganar visibilidad local.',
        illo: 'local',
      },
      {
        number: '04',
        title: 'Visibilidad en IA',
        lead: 'Constrúyelo una vez. Visible en todos lados.',
        body: 'La estructura que posiciona en Google te hace visible para los modelos de IA. Cuando alguien pregunta a ChatGPT "mejor agente inmobiliario en Madrid Salamanca", aparecen los agentes con señales de entidad consistentes en web, GBP y contenido local.',
        illo: 'ai',
      },
    ],
  },
}

const t = copy[locale] ?? copy.de
const h = headline ?? t.defaultHeadline
---

<section id="offer" class="strategy">
  <div class="strategy__inner">
    <header class="strategy__header">
      <span class="strategy__eyebrow">{t.eyebrow}</span>
      <h2 class="strategy__headline">{h}</h2>
    </header>

    <div class="strategy__scroll">
      <div class="strategy__pin">
        <div class="strategy__grid">
          <!-- LEFT: stacked pillars, crossfade -->
          <ol class="strategy__col strategy__col--left" aria-label="Strategy pillars">
            {t.pillars.map((pillar, i) => (
              <li class="pillar" data-pillar-index={i}>
                <div class="pillar__inner">
                  <span class="pillar__number">{pillar.number}</span>
                  <h3 class="pillar__title">{pillar.title}</h3>
                  <p class="pillar__lead">{pillar.lead}</p>
                  <p class="pillar__body">{pillar.body}</p>
                </div>
              </li>
            ))}
          </ol>

          <!-- RIGHT: stacked illustrations, crossfade (staggered) -->
          <aside class="strategy__col strategy__col--right" aria-hidden="true">

          <!-- 01 Entity Consistency — 3 cards sharing one identity -->
          <svg class="illo" data-illo="entity" viewBox="0 0 480 480" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- Spine: single accent line -->
            <line x1="240" y1="110" x2="240" y2="370" stroke="var(--accent)" stroke-width="2" />

            <!-- GBP card (dark) -->
            <g>
              <rect x="90" y="80" width="300" height="70" rx="8" fill="#1d1d1f" />
              <text x="110" y="108" font-family="Chivo, sans-serif" font-size="11" font-weight="600" fill="rgba(255,255,255,0.55)" letter-spacing="0.08em">GOOGLE BUSINESS PROFILE</text>
              <text x="110" y="132" font-family="Clash Display, sans-serif" font-size="18" font-weight="600" fill="white" letter-spacing="-0.01em">Immobilienmakler · Hamburg</text>
            </g>

            <!-- Website card (light) -->
            <g>
              <rect x="90" y="210" width="300" height="70" rx="8" fill="white" stroke="rgba(0,0,0,0.08)" />
              <text x="110" y="238" font-family="Chivo, sans-serif" font-size="11" font-weight="600" fill="rgba(0,0,0,0.48)" letter-spacing="0.08em">WEBSITE</text>
              <text x="110" y="262" font-family="Clash Display, sans-serif" font-size="18" font-weight="600" fill="#1d1d1f" letter-spacing="-0.01em">Immobilienmakler · Hamburg</text>
            </g>

            <!-- AI card (accent) -->
            <g>
              <rect x="90" y="340" width="300" height="70" rx="8" fill="var(--accent)" />
              <text x="110" y="368" font-family="Chivo, sans-serif" font-size="11" font-weight="600" fill="rgba(255,255,255,0.7)" letter-spacing="0.08em">AI &amp; DIRECTORIES</text>
              <text x="110" y="392" font-family="Clash Display, sans-serif" font-size="18" font-weight="600" fill="white" letter-spacing="-0.01em">Immobilienmakler · Hamburg</text>
            </g>

            <!-- Connector nodes -->
            <circle cx="240" cy="115" r="5" fill="var(--accent)" />
            <circle cx="240" cy="245" r="5" fill="var(--accent)" />
            <circle cx="240" cy="375" r="5" fill="var(--accent)" />
          </svg>

          <!-- 02 Core Structure — site tree as typography -->
          <svg class="illo" data-illo="structure" viewBox="0 0 480 480" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- Level 1: homepage -->
            <g>
              <rect x="170" y="50" width="140" height="46" rx="8" fill="#1d1d1f" />
              <text x="240" y="79" text-anchor="middle" font-family="Clash Display, sans-serif" font-size="16" font-weight="600" fill="white" letter-spacing="-0.01em">Home</text>
            </g>

            <!-- Connector -->
            <line x1="240" y1="96" x2="240" y2="140" stroke="var(--accent)" stroke-width="2" />
            <line x1="100" y1="140" x2="380" y2="140" stroke="var(--accent)" stroke-width="2" />
            <line x1="100" y1="140" x2="100" y2="170" stroke="var(--accent)" stroke-width="2" />
            <line x1="240" y1="140" x2="240" y2="170" stroke="var(--accent)" stroke-width="2" />
            <line x1="380" y1="140" x2="380" y2="170" stroke="var(--accent)" stroke-width="2" />

            <!-- Level 2: services -->
            <g>
              <rect x="40" y="170" width="120" height="40" rx="6" fill="white" stroke="rgba(0,0,0,0.08)" />
              <text x="100" y="195" text-anchor="middle" font-family="Clash Display, sans-serif" font-size="14" font-weight="600" fill="#1d1d1f" letter-spacing="-0.01em">Verkauf</text>
            </g>
            <g>
              <rect x="180" y="170" width="120" height="40" rx="6" fill="white" stroke="rgba(0,0,0,0.08)" />
              <text x="240" y="195" text-anchor="middle" font-family="Clash Display, sans-serif" font-size="14" font-weight="600" fill="#1d1d1f" letter-spacing="-0.01em">Vermietung</text>
            </g>
            <g>
              <rect x="320" y="170" width="120" height="40" rx="6" fill="white" stroke="rgba(0,0,0,0.08)" />
              <text x="380" y="195" text-anchor="middle" font-family="Clash Display, sans-serif" font-size="14" font-weight="600" fill="#1d1d1f" letter-spacing="-0.01em">Bewertung</text>
            </g>

            <!-- Connectors to level 3 -->
            <line x1="100" y1="210" x2="100" y2="240" stroke="var(--accent)" stroke-width="2" opacity="0.4" />
            <line x1="70" y1="240" x2="130" y2="240" stroke="var(--accent)" stroke-width="2" opacity="0.4" />
            <line x1="70" y1="240" x2="70" y2="265" stroke="var(--accent)" stroke-width="2" opacity="0.4" />
            <line x1="130" y1="240" x2="130" y2="265" stroke="var(--accent)" stroke-width="2" opacity="0.4" />

            <line x1="240" y1="210" x2="240" y2="240" stroke="var(--accent)" stroke-width="2" opacity="0.4" />
            <line x1="210" y1="240" x2="270" y2="240" stroke="var(--accent)" stroke-width="2" opacity="0.4" />
            <line x1="210" y1="240" x2="210" y2="265" stroke="var(--accent)" stroke-width="2" opacity="0.4" />
            <line x1="270" y1="240" x2="270" y2="265" stroke="var(--accent)" stroke-width="2" opacity="0.4" />

            <line x1="380" y1="210" x2="380" y2="240" stroke="var(--accent)" stroke-width="2" opacity="0.4" />
            <line x1="350" y1="240" x2="410" y2="240" stroke="var(--accent)" stroke-width="2" opacity="0.4" />
            <line x1="350" y1="240" x2="350" y2="265" stroke="var(--accent)" stroke-width="2" opacity="0.4" />
            <line x1="410" y1="240" x2="410" y2="265" stroke="var(--accent)" stroke-width="2" opacity="0.4" />

            <!-- Level 3: neighborhoods -->
            <g>
              <rect x="30" y="265" width="80" height="32" rx="5" fill="#f5f5f7" />
              <text x="70" y="286" text-anchor="middle" font-family="Chivo, sans-serif" font-size="12" font-weight="600" fill="#1d1d1f">Altona</text>
            </g>
            <g>
              <rect x="90" y="265" width="80" height="32" rx="5" fill="#f5f5f7" />
              <text x="130" y="286" text-anchor="middle" font-family="Chivo, sans-serif" font-size="12" font-weight="600" fill="#1d1d1f">Eimsbüttel</text>
            </g>
            <g>
              <rect x="170" y="265" width="80" height="32" rx="5" fill="#f5f5f7" />
              <text x="210" y="286" text-anchor="middle" font-family="Chivo, sans-serif" font-size="12" font-weight="600" fill="#1d1d1f">Altona</text>
            </g>
            <g>
              <rect x="230" y="265" width="80" height="32" rx="5" fill="#f5f5f7" />
              <text x="270" y="286" text-anchor="middle" font-family="Chivo, sans-serif" font-size="12" font-weight="600" fill="#1d1d1f">HafenCity</text>
            </g>
            <g>
              <rect x="305" y="265" width="90" height="32" rx="5" fill="#f5f5f7" />
              <text x="350" y="286" text-anchor="middle" font-family="Chivo, sans-serif" font-size="11" font-weight="600" fill="#1d1d1f">Eppendorf</text>
            </g>
            <g>
              <rect x="370" y="265" width="80" height="32" rx="5" fill="#f5f5f7" />
              <text x="410" y="286" text-anchor="middle" font-family="Chivo, sans-serif" font-size="12" font-weight="600" fill="#1d1d1f">Winterhude</text>
            </g>

            <!-- Pattern label -->
            <text x="240" y="370" text-anchor="middle" font-family="Chivo, sans-serif" font-size="11" font-weight="600" fill="rgba(0,0,0,0.48)" letter-spacing="0.1em">SERVICE × STADTTEIL</text>
          </svg>

          <!-- 03 Local Content Depth — typography as the illustration -->
          <svg class="illo" data-illo="local" viewBox="0 0 480 480" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- Altona block -->
            <g>
              <text x="40" y="110" font-family="Clash Display, sans-serif" font-size="54" font-weight="600" fill="#1d1d1f" letter-spacing="-0.03em">Altona</text>
              <text x="40" y="136" font-family="Chivo, sans-serif" font-size="14" font-weight="500" fill="rgba(0,0,0,0.48)">€5.800/m² · Altbau · 39% Familien</text>
            </g>

            <!-- Divider -->
            <line x1="40" y1="170" x2="440" y2="170" stroke="rgba(0,0,0,0.08)" stroke-width="1" />

            <!-- Eimsbüttel block -->
            <g>
              <text x="40" y="225" font-family="Clash Display, sans-serif" font-size="54" font-weight="600" fill="var(--accent)" letter-spacing="-0.03em">Eimsbüttel</text>
              <text x="40" y="251" font-family="Chivo, sans-serif" font-size="14" font-weight="500" fill="rgba(0,0,0,0.48)">€6.200/m² · gemischt · Young Professionals</text>
            </g>

            <line x1="40" y1="285" x2="440" y2="285" stroke="rgba(0,0,0,0.08)" stroke-width="1" />

            <!-- HafenCity block -->
            <g>
              <text x="40" y="340" font-family="Clash Display, sans-serif" font-size="54" font-weight="600" fill="#1d1d1f" letter-spacing="-0.03em">HafenCity</text>
              <text x="40" y="366" font-family="Chivo, sans-serif" font-size="14" font-weight="500" fill="rgba(0,0,0,0.48)">€9.500/m² · Neubau · Kapitalanlage</text>
            </g>

            <line x1="40" y1="400" x2="440" y2="400" stroke="rgba(0,0,0,0.08)" stroke-width="1" />

            <!-- Footer tag -->
            <text x="40" y="435" font-family="Chivo, sans-serif" font-size="11" font-weight="600" fill="rgba(0,0,0,0.48)" letter-spacing="0.1em">+ 12 WEITERE STADTTEILE</text>
          </svg>

          <!-- 04 AI Visibility — query and results, minimal -->
          <svg class="illo" data-illo="ai" viewBox="0 0 480 480" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- Query pill -->
            <g>
              <rect x="20" y="50" width="440" height="68" rx="34" fill="#1d1d1f" />
              <text x="45" y="82" font-family="Chivo, sans-serif" font-size="11" font-weight="600" fill="rgba(255,255,255,0.48)" letter-spacing="0.1em">PROMPT</text>
              <text x="45" y="104" font-family="Clash Display, sans-serif" font-size="16" font-weight="500" fill="white" letter-spacing="-0.01em">„Bester Makler in Hamburg-Altona?"</text>
            </g>

            <!-- Fan-out -->
            <line x1="240" y1="118" x2="240" y2="170" stroke="var(--accent)" stroke-width="2" />
            <line x1="120" y1="170" x2="360" y2="170" stroke="var(--accent)" stroke-width="2" />
            <line x1="120" y1="170" x2="120" y2="200" stroke="var(--accent)" stroke-width="2" />
            <line x1="240" y1="170" x2="240" y2="200" stroke="var(--accent)" stroke-width="2" />
            <line x1="360" y1="170" x2="360" y2="200" stroke="var(--accent)" stroke-width="2" />

            <!-- 3 result cards -->
            <g>
              <rect x="40" y="200" width="160" height="90" rx="8" fill="white" stroke="rgba(0,0,0,0.08)" />
              <text x="60" y="224" font-family="Chivo, sans-serif" font-size="10" font-weight="600" fill="rgba(0,0,0,0.48)" letter-spacing="0.08em">CHATGPT</text>
              <text x="60" y="254" font-family="Clash Display, sans-serif" font-size="17" font-weight="600" fill="#1d1d1f" letter-spacing="-0.01em">Nestor S.</text>
              <text x="60" y="276" font-family="Chivo, sans-serif" font-size="11" fill="var(--accent)">nestorsegura.com</text>
            </g>

            <g>
              <rect x="160" y="200" width="160" height="90" rx="8" fill="var(--accent)" />
              <text x="180" y="224" font-family="Chivo, sans-serif" font-size="10" font-weight="600" fill="rgba(255,255,255,0.7)" letter-spacing="0.08em">GOOGLE</text>
              <text x="180" y="254" font-family="Clash Display, sans-serif" font-size="17" font-weight="600" fill="white" letter-spacing="-0.01em">Nestor S.</text>
              <text x="180" y="276" font-family="Chivo, sans-serif" font-size="11" fill="rgba(255,255,255,0.85)">nestorsegura.com</text>
            </g>

            <g>
              <rect x="280" y="200" width="160" height="90" rx="8" fill="white" stroke="rgba(0,0,0,0.08)" />
              <text x="300" y="224" font-family="Chivo, sans-serif" font-size="10" font-weight="600" fill="rgba(0,0,0,0.48)" letter-spacing="0.08em">PERPLEXITY</text>
              <text x="300" y="254" font-family="Clash Display, sans-serif" font-size="17" font-weight="600" fill="#1d1d1f" letter-spacing="-0.01em">Nestor S.</text>
              <text x="300" y="276" font-family="Chivo, sans-serif" font-size="11" fill="var(--accent)">nestorsegura.com</text>
            </g>

            <!-- Caption -->
            <text x="240" y="370" text-anchor="middle" font-family="Clash Display, sans-serif" font-size="24" font-weight="600" fill="#1d1d1f" letter-spacing="-0.02em">Überall dieselbe Antwort.</text>
            <text x="240" y="400" text-anchor="middle" font-family="Chivo, sans-serif" font-size="14" font-weight="400" fill="rgba(0,0,0,0.48)">Weil die Entität konsistent ist.</text>
          </svg>

          </aside>
        </div>
      </div>
      <!-- scroll steps: drive the active pillar via IO -->
      <div class="strategy__step" data-step="0"></div>
      <div class="strategy__step" data-step="1"></div>
      <div class="strategy__step" data-step="2"></div>
      <div class="strategy__step" data-step="3"></div>
    </div>

    {ctaHref && ctaLabel && (
      <div class="strategy__cta">
        <a href={ctaHref} class="strategy__cta-btn">
          {ctaLabel}
          <span class="strategy__cta-arrow" aria-hidden="true">→</span>
        </a>
      </div>
    )}
  </div>
</section>

<style is:global>
.strategy {
  --accent: oklch(0.58 0.20 290);
  --ink: #1d1d1f;
  --surface: #f5f5f7;

  background-color: var(--surface);
  color: var(--ink);
  padding-top: clamp(5rem, 12vh, 10rem);
  padding-bottom: clamp(5rem, 12vh, 10rem);
}

.strategy__inner {
  max-width: 80rem;
  margin: 0 auto;
  padding: 0 1.5rem;
}

.strategy__header {
  max-width: 56rem;
  margin-bottom: clamp(2rem, 6vh, 4rem);
}

.strategy__eyebrow {
  display: inline-block;
  font-family: 'Chivo', sans-serif;
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 1.25rem;
}

.strategy__headline {
  font-family: 'Clash Display', sans-serif;
  font-size: clamp(2.25rem, 5vw, 3.5rem);
  font-weight: 600;
  line-height: 1.07;
  letter-spacing: -0.02em;
  color: var(--ink);
  margin: 0;
  max-width: 20ch;
}

/* ── Scroll choreography ─────────────────────────────────────────── */
.strategy__scroll {
  position: relative;
}

.strategy__pin {
  position: sticky;
  top: 6rem;
  height: auto;
  min-height: 32rem;
  display: grid;
  place-items: start center;
  pointer-events: none;
}

.strategy__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 3rem;
  width: 100%;
  pointer-events: auto;
}

@media (min-width: 900px) {
  .strategy__grid {
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 6rem;
    align-items: center;
  }
}

/* Columns are stacking contexts — children crossfade in place */
.strategy__col {
  position: relative;
  list-style: none;
  margin: 0;
  padding: 0;
}

.strategy__col--left {
  min-height: 22rem;
}

.strategy__col--right {
  display: none;
}

@media (min-width: 900px) {
  .strategy__col--right {
    display: block;
    aspect-ratio: 1 / 1;
    max-width: 30rem;
    margin-left: auto;
    margin-right: auto;
    width: 100%;
  }
}

/* Invisible trigger strips drive which pillar is active.
   Shorter than 100vh = tighter total scroll range, less empty space. */
.strategy__step {
  height: 60vh;
  pointer-events: none;
}

/* ── Pillars (left) ──────────────────────────────────────────────── */
.pillar {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: flex-start;
  opacity: 0;
  transition: opacity 0.55s ease;
  pointer-events: none;
}

.pillar.is-active {
  opacity: 1;
  pointer-events: auto;
}

.pillar__inner {
  max-width: 34rem;
}

.pillar__number {
  display: block;
  font-family: 'Chivo', sans-serif;
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--accent);
  margin-bottom: 1.5rem;
  letter-spacing: 0.12em;
}

.pillar__title {
  font-family: 'Clash Display', sans-serif;
  font-size: clamp(1.75rem, 3.5vw, 2.5rem);
  font-weight: 600;
  line-height: 1.1;
  letter-spacing: -0.02em;
  color: var(--ink);
  margin: 0 0 1rem 0;
}

.pillar__lead {
  font-family: 'Clash Display', sans-serif;
  font-size: clamp(1.0625rem, 1.6vw, 1.3125rem);
  font-weight: 500;
  line-height: 1.19;
  letter-spacing: -0.01em;
  color: var(--accent);
  margin: 0 0 1.5rem 0;
}

.pillar__body {
  font-family: 'Chivo', sans-serif;
  font-size: 1.0625rem;
  line-height: 1.47;
  letter-spacing: -0.012em;
  color: rgba(0, 0, 0, 0.8);
  margin: 0;
}

/* ── Illustrations (right) — staggered behind the text ───────────── */
.illo {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  transform: scale(0.97);
  transition: opacity 0.6s ease 0.18s, transform 0.7s ease 0.18s;
  color: var(--ink);
}

.illo.is-active {
  opacity: 1;
  transform: scale(1);
}

/* Mobile (<900px): stack pillars inline at full opacity, no scroll pin */
@media (max-width: 899px) {
  .strategy__pin {
    position: static;
    height: auto;
    display: block;
  }

  .strategy__col--left {
    min-height: 0;
  }

  .pillar {
    position: relative;
    inset: auto;
    opacity: 1;
    padding: 3rem 0;
    pointer-events: auto;
  }

  .strategy__step {
    display: none;
  }
}

/* ── CTA ─────────────────────────────────────────────────────────── */
.strategy__cta {
  margin-top: clamp(2rem, 6vh, 4rem);
  text-align: center;
}

.strategy__cta-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.625rem;
  background: var(--ink);
  color: white;
  font-family: 'Chivo', sans-serif;
  font-weight: 500;
  font-size: 1.0625rem;
  letter-spacing: -0.012em;
  padding: 1rem 2rem;
  border-radius: 980px;
  text-decoration: none;
  transition: background-color 0.2s ease, transform 0.18s ease;
}

.strategy__cta-btn:hover {
  background: var(--accent);
  transform: translateY(-1px);
}

.strategy__cta-arrow {
  transition: transform 0.2s ease;
}

.strategy__cta-btn:hover .strategy__cta-arrow {
  transform: translateX(3px);
}
</style>

<script is:inline>
  (function () {
    var pillars = Array.from(document.querySelectorAll('.pillar[data-pillar-index]'));
    var illos = Array.from(document.querySelectorAll('.illo[data-illo]'));
    var steps = Array.from(document.querySelectorAll('.strategy__step[data-step]'));
    if (!pillars.length || !illos.length || !steps.length) return;

    function setActive(index) {
      pillars.forEach(function (p, i) { p.classList.toggle('is-active', i === index); });
      illos.forEach(function (s, i) { s.classList.toggle('is-active', i === index); });
    }

    // Seed step 0 (so first pillar is visible immediately on entry)
    setActive(0);

    var io = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            var i = parseInt(entry.target.getAttribute('data-step'), 10);
            if (!isNaN(i)) setActive(i);
          }
        });
      },
      { rootMargin: '-45% 0px -45% 0px', threshold: 0 }
    );

    steps.forEach(function (s) { io.observe(s); });
  })();
</script>
