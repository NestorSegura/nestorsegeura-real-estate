---
import type { Locale } from '../../i18n/utils'

interface Props {
  locale: Locale
  headline?: string
  ctaLabel?: string
  ctaHref?: string
  // Legacy props (from Sanity) accepted but not rendered in new design
  comparison?: unknown
  services?: unknown
  [key: string]: unknown
}

const { locale, headline, ctaLabel, ctaHref } = Astro.props

const copy = {
  de: {
    eyebrow: 'Die Strategie in 4 Säulen',
    defaultHeadline: 'Warum diese Methode bei Google UND bei ChatGPT funktioniert',
    pillars: [
      {
        number: '01',
        title: 'Entitäts-Konsistenz',
        lead: 'Google matcht keine Keywords mehr — Google matcht Entitäten.',
        body: 'Dein Google Business Profil, deine Website und deine Online-Präsenz müssen exakt dieselbe Geschichte erzählen. Bei den meisten Maklern klafft eine Lücke zwischen dem, was im GBP steht, und dem, was die Website zeigt. Jede Lücke kostet Vertrauen — bei Google und bei den KI-Modellen (ChatGPT, Perplexity, Gemini bewerten lokale Unternehmen nach demselben Muster).',
        illo: 'entity',
      },
      {
        number: '02',
        title: 'Die Kernstruktur',
        lead: 'Eine Seite pro Leistung. Eine Seite pro Stadtteil. Keine Ausnahmen.',
        body: 'Homepage zielt auf Primär-Kategorie + Stadt (z. B. „Immobilienmakler Hamburg"). Jede Dienstleistung bekommt eine eigene Seite. Jeder Stadtteil, in dem du verkaufen willst, bekommt eine eigene Seite. Die interne Verlinkung spiegelt die GBP-Hierarchie exakt. So baut Google Vertrauen auf, dass dein Unternehmen real und lokal ist.',
        illo: 'structure',
      },
      {
        number: '03',
        title: 'Lokale Inhalts-Tiefe',
        lead: 'Generische Inhalte ranken nicht lokal. Punkt.',
        body: 'Ein Makler in Hamburg muss über Altona vs. Eimsbüttel Preisdynamiken sprechen, über Altbau vs. Neubauten, über das Käuferprofil im konkreten Viertel. Ein Makler in München über Schwabing vs. Giesing. Inhalte, die lokale Begriffe, Marktbedingungen und Immobilientypen referenzieren — das ist der einzige Weg, lokal sichtbar zu werden.',
        illo: 'local',
      },
      {
        number: '04',
        title: 'KI-Sichtbarkeit',
        lead: 'Einmal bauen, überall sichtbar.',
        body: 'Die gleiche Struktur, die bei Google rankt, macht dich für KI-Modelle auffindbar. Wenn jemand ChatGPT fragt „Bester Immobilienmakler in Hamburg-Altona", erscheinen die Makler mit konsistenten Entitäts-Signalen über Web + GBP + lokale Inhalte. Das ist die Zukunft der lokalen Suche — und sie hat schon begonnen.',
        illo: 'ai',
      },
    ],
  },
  en: {
    eyebrow: 'The strategy in 4 pillars',
    defaultHeadline: 'Why this method works on Google AND on ChatGPT',
    pillars: [
      {
        number: '01',
        title: 'Entity Consistency',
        lead: 'Google no longer matches keywords — it matches entities.',
        body: 'Your Google Business Profile, your website, and your online presence must tell the exact same story. Most agents have gaps between what their profile says and what their website shows. Every gap costs trust — with Google, and with the AI models (ChatGPT, Perplexity, Gemini all evaluate local businesses the same way).',
        illo: 'entity',
      },
      {
        number: '02',
        title: 'The Core Structure',
        lead: 'One page per service. One page per area. No exceptions.',
        body: 'Homepage targets primary category + city ("Real estate agent Hamburg"). Each service gets its own page. Each location you want to rank in gets its own page. Internal linking mirrors the GBP hierarchy exactly. This is how Google gains confidence that your business is legitimate and local.',
        illo: 'structure',
      },
      {
        number: '03',
        title: 'Local Content Depth',
        lead: 'Generic content does not rank locally. Full stop.',
        body: 'An agent in Hamburg should talk about Altona vs. Eimsbüttel price dynamics, Altbau vs. new-build specifics, the local buyer profile. An agent in Munich about Schwabing vs. Giesing. Content that references specific neighborhoods, market conditions, and property types is the only way to become visible locally.',
        illo: 'local',
      },
      {
        number: '04',
        title: 'AI Visibility',
        lead: 'Build once, visible everywhere.',
        body: 'The same structure that ranks on Google makes you visible to AI models. When someone asks ChatGPT "best real estate agent in Hamburg Altona", the agents with consistent entity signals across web + GBP + local content appear. This is the future of local search — and it has already started.',
        illo: 'ai',
      },
    ],
  },
  es: {
    eyebrow: 'La estrategia en 4 pilares',
    defaultHeadline: 'Por qué este método funciona en Google Y en ChatGPT',
    pillars: [
      {
        number: '01',
        title: 'Consistencia de Entidad',
        lead: 'Google ya no empareja palabras clave — empareja entidades.',
        body: 'Tu perfil de Google Business, tu web y tu presencia online deben contar exactamente la misma historia. La mayoría de agentes tiene huecos entre lo que dice su perfil y lo que muestra su web. Cada hueco cuesta confianza — con Google, y con los modelos de IA (ChatGPT, Perplexity, Gemini evalúan los negocios locales igual).',
        illo: 'entity',
      },
      {
        number: '02',
        title: 'La Estructura Base',
        lead: 'Una página por servicio. Una página por zona. Sin excepciones.',
        body: 'La home apunta a categoría principal + ciudad ("Agente inmobiliario Madrid"). Cada servicio tiene su propia página. Cada zona donde quieres posicionar tiene su propia página. El enlazado interno refleja exactamente la jerarquía del GBP. Así Google gana confianza de que tu negocio es real y local.',
        illo: 'structure',
      },
      {
        number: '03',
        title: 'Profundidad Local del Contenido',
        lead: 'El contenido genérico no posiciona localmente. Punto.',
        body: 'Un agente en Madrid debe hablar de la dinámica de precios Salamanca vs. Chamberí, de pisos antiguos vs. obra nueva, del perfil del comprador del barrio. Un agente en Barcelona del Eixample vs. Gràcia. Contenido que referencia barrios concretos, condiciones de mercado y tipos de vivienda es la única vía para ganar visibilidad local.',
        illo: 'local',
      },
      {
        number: '04',
        title: 'Visibilidad en IA',
        lead: 'Constrúyelo una vez, visible en todos lados.',
        body: 'La misma estructura que posiciona en Google te hace visible para los modelos de IA. Cuando alguien pregunta a ChatGPT "mejor agente inmobiliario en Madrid Salamanca", aparecen los agentes con señales de entidad consistentes en web + GBP + contenido local. Este es el futuro de la búsqueda local — y ya ha empezado.',
        illo: 'ai',
      },
    ],
  },
}

const t = copy[locale] ?? copy.de
const h = headline ?? t.defaultHeadline
---

<section id="offer" class="strategy">
  <div class="strategy__inner">
    <header class="strategy__header">
      <span class="strategy__eyebrow">{t.eyebrow}</span>
      <h2 class="strategy__headline">{h}</h2>
    </header>

    <div class="strategy__grid">
      <!-- LEFT: scrolling pillars -->
      <ol class="strategy__pillars" data-strategy-pillars>
        {t.pillars.map((pillar, i) => (
          <li class="pillar" data-pillar-index={i} data-pillar-illo={pillar.illo}>
            <span class="pillar__number">{pillar.number}</span>
            <h3 class="pillar__title">{pillar.title}</h3>
            <p class="pillar__lead">{pillar.lead}</p>
            <p class="pillar__body">{pillar.body}</p>
          </li>
        ))}
      </ol>

      <!-- RIGHT: sticky illustration stage -->
      <aside class="strategy__stage" aria-hidden="true">
        <div class="strategy__sticky">
          <!-- Entity Consistency -->
          <svg class="illo" data-illo="entity" viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <filter id="softshadow" x="-20%" y="-20%" width="140%" height="140%">
                <feGaussianBlur in="SourceAlpha" stdDeviation="4" />
                <feOffset dx="0" dy="4" result="offsetblur" />
                <feComponentTransfer><feFuncA type="linear" slope="0.15" /></feComponentTransfer>
                <feMerge><feMergeNode /><feMergeNode in="SourceGraphic" /></feMerge>
              </filter>
            </defs>

            <!-- Connection lines -->
            <path d="M120 130 L280 130 M120 270 L280 270 M120 130 L200 260 M280 130 L200 260 M120 270 L280 270" stroke="currentColor" stroke-width="2" stroke-dasharray="4 6" opacity="0.35" />
            <path d="M120 130 L280 130" stroke="var(--brand-purple, oklch(0.58 0.20 290))" stroke-width="3" />
            <path d="M120 130 L200 260" stroke="var(--brand-purple, oklch(0.58 0.20 290))" stroke-width="3" />
            <path d="M280 130 L200 260" stroke="var(--brand-purple, oklch(0.58 0.20 290))" stroke-width="3" />

            <!-- GBP node -->
            <g filter="url(#softshadow)">
              <rect x="60" y="100" width="120" height="60" rx="10" fill="white" stroke="currentColor" stroke-width="1.5" />
              <text x="120" y="125" text-anchor="middle" font-family="Chivo, sans-serif" font-size="10" font-weight="600" fill="currentColor" opacity="0.55">GOOGLE BUSINESS</text>
              <text x="120" y="145" text-anchor="middle" font-family="Clash Display, sans-serif" font-size="14" font-weight="600" fill="currentColor">Immobilienmakler</text>
            </g>

            <!-- Website node -->
            <g filter="url(#softshadow)">
              <rect x="220" y="100" width="120" height="60" rx="10" fill="white" stroke="currentColor" stroke-width="1.5" />
              <text x="280" y="125" text-anchor="middle" font-family="Chivo, sans-serif" font-size="10" font-weight="600" fill="currentColor" opacity="0.55">WEBSITE</text>
              <text x="280" y="145" text-anchor="middle" font-family="Clash Display, sans-serif" font-size="14" font-weight="600" fill="currentColor">Immobilienmakler</text>
            </g>

            <!-- AI/Directory node -->
            <g filter="url(#softshadow)">
              <rect x="140" y="240" width="120" height="60" rx="10" fill="var(--brand-purple, oklch(0.58 0.20 290))" />
              <text x="200" y="265" text-anchor="middle" font-family="Chivo, sans-serif" font-size="10" font-weight="600" fill="white" opacity="0.7">AI &amp; DIRECTORIES</text>
              <text x="200" y="285" text-anchor="middle" font-family="Clash Display, sans-serif" font-size="14" font-weight="600" fill="white">Immobilienmakler</text>
            </g>

            <!-- Check badge -->
            <circle cx="200" cy="200" r="22" fill="white" stroke="var(--brand-purple, oklch(0.58 0.20 290))" stroke-width="2" />
            <path d="M190 200 l6 6 l12 -12" stroke="var(--brand-purple, oklch(0.58 0.20 290))" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" fill="none" />
          </svg>

          <!-- Core Structure -->
          <svg class="illo" data-illo="structure" viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- Root: homepage -->
            <g>
              <rect x="150" y="40" width="100" height="40" rx="6" fill="var(--brand-purple, oklch(0.58 0.20 290))" />
              <text x="200" y="65" text-anchor="middle" font-family="Clash Display, sans-serif" font-size="13" font-weight="600" fill="white">Home</text>
            </g>

            <!-- Level 2: categories -->
            <path d="M200 80 L80 140 M200 80 L200 140 M200 80 L320 140" stroke="currentColor" stroke-width="1.5" opacity="0.4" />

            <g>
              <rect x="30" y="140" width="100" height="36" rx="6" fill="white" stroke="currentColor" stroke-width="1.2" />
              <text x="80" y="163" text-anchor="middle" font-family="Chivo, sans-serif" font-size="11" font-weight="600" fill="currentColor">Verkauf</text>
            </g>
            <g>
              <rect x="150" y="140" width="100" height="36" rx="6" fill="white" stroke="currentColor" stroke-width="1.2" />
              <text x="200" y="163" text-anchor="middle" font-family="Chivo, sans-serif" font-size="11" font-weight="600" fill="currentColor">Vermietung</text>
            </g>
            <g>
              <rect x="270" y="140" width="100" height="36" rx="6" fill="white" stroke="currentColor" stroke-width="1.2" />
              <text x="320" y="163" text-anchor="middle" font-family="Chivo, sans-serif" font-size="11" font-weight="600" fill="currentColor">Bewertung</text>
            </g>

            <!-- Level 3: locations -->
            <path d="M80 176 L60 240 M80 176 L100 240 M200 176 L180 240 M200 176 L220 240 M320 176 L300 240 M320 176 L340 240" stroke="currentColor" stroke-width="1.2" opacity="0.35" />

            <g>
              <rect x="20" y="240" width="80" height="30" rx="5" fill="white" stroke="currentColor" stroke-width="1" />
              <text x="60" y="260" text-anchor="middle" font-family="Chivo, sans-serif" font-size="10" fill="currentColor">Altona</text>
            </g>
            <g>
              <rect x="120" y="240" width="80" height="30" rx="5" fill="white" stroke="currentColor" stroke-width="1" />
              <text x="160" y="260" text-anchor="middle" font-family="Chivo, sans-serif" font-size="10" fill="currentColor">Eimsbüttel</text>
            </g>
            <g>
              <rect x="220" y="240" width="80" height="30" rx="5" fill="white" stroke="currentColor" stroke-width="1" />
              <text x="260" y="260" text-anchor="middle" font-family="Chivo, sans-serif" font-size="10" fill="currentColor">Altona</text>
            </g>
            <g>
              <rect x="320" y="240" width="70" height="30" rx="5" fill="white" stroke="currentColor" stroke-width="1" />
              <text x="355" y="260" text-anchor="middle" font-family="Chivo, sans-serif" font-size="10" fill="currentColor">HH-Mitte</text>
            </g>

            <!-- Tag showing the pattern -->
            <g transform="translate(120,320)">
              <rect width="160" height="40" rx="20" fill="var(--brand-purple, oklch(0.58 0.20 290))" opacity="0.12" />
              <text x="80" y="25" text-anchor="middle" font-family="Chivo, sans-serif" font-size="12" font-weight="600" fill="var(--brand-purple, oklch(0.58 0.20 290))">Service × Stadtteil</text>
            </g>
          </svg>

          <!-- Local Content Depth -->
          <svg class="illo" data-illo="local" viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- Map/city outline -->
            <path d="M60 80 Q100 60 160 70 Q240 80 300 60 Q340 70 360 120 Q355 180 330 220 Q340 280 300 330 Q240 340 180 320 Q120 330 80 300 Q50 240 60 180 Z" fill="white" stroke="currentColor" stroke-width="1.5" opacity="0.6" />

            <!-- River -->
            <path d="M70 150 Q150 170 220 140 Q290 120 350 160" stroke="var(--brand-purple, oklch(0.58 0.20 290))" stroke-width="3" opacity="0.25" fill="none" />

            <!-- Neighborhood pins -->
            <g>
              <circle cx="120" cy="130" r="10" fill="var(--brand-purple, oklch(0.58 0.20 290))" />
              <circle cx="120" cy="130" r="4" fill="white" />
              <text x="135" y="124" font-family="Clash Display, sans-serif" font-size="13" font-weight="600" fill="currentColor">Altona</text>
              <text x="135" y="140" font-family="Chivo, sans-serif" font-size="10" fill="currentColor" opacity="0.6">€5.800/m² · Altbau</text>
            </g>

            <g>
              <circle cx="220" cy="210" r="10" fill="var(--brand-purple, oklch(0.58 0.20 290))" />
              <circle cx="220" cy="210" r="4" fill="white" />
              <text x="235" y="204" font-family="Clash Display, sans-serif" font-size="13" font-weight="600" fill="currentColor">Eimsbüttel</text>
              <text x="235" y="220" font-family="Chivo, sans-serif" font-size="10" fill="currentColor" opacity="0.6">€6.200/m² · gemischt</text>
            </g>

            <g>
              <circle cx="150" cy="270" r="10" fill="var(--brand-purple, oklch(0.58 0.20 290))" />
              <circle cx="150" cy="270" r="4" fill="white" />
              <text x="165" y="264" font-family="Clash Display, sans-serif" font-size="13" font-weight="600" fill="currentColor">HafenCity</text>
              <text x="165" y="280" font-family="Chivo, sans-serif" font-size="10" fill="currentColor" opacity="0.6">€9.500/m² · Neubau</text>
            </g>

            <g>
              <circle cx="300" cy="280" r="10" fill="currentColor" opacity="0.35" />
              <text x="260" y="310" font-family="Chivo, sans-serif" font-size="10" fill="currentColor" opacity="0.5">+ weitere</text>
            </g>
          </svg>

          <!-- AI Visibility -->
          <svg class="illo" data-illo="ai" viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- Prompt bubble -->
            <g>
              <rect x="60" y="40" width="280" height="60" rx="14" fill="white" stroke="currentColor" stroke-width="1.5" />
              <text x="80" y="65" font-family="Chivo, sans-serif" font-size="11" font-weight="600" fill="currentColor" opacity="0.5">PROMPT</text>
              <text x="80" y="85" font-family="Clash Display, sans-serif" font-size="13" font-weight="500" fill="currentColor">"Bester Immobilienmakler in Hamburg Altona?"</text>
            </g>

            <!-- Fan-out arrows -->
            <path d="M200 100 Q140 150 100 210 M200 100 Q200 150 200 210 M200 100 Q260 150 300 210" stroke="var(--brand-purple, oklch(0.58 0.20 290))" stroke-width="2" stroke-dasharray="4 4" fill="none" />

            <!-- ChatGPT bubble -->
            <g>
              <rect x="40" y="210" width="130" height="70" rx="10" fill="white" stroke="currentColor" stroke-width="1.2" />
              <text x="55" y="232" font-family="Chivo, sans-serif" font-size="10" font-weight="600" fill="currentColor" opacity="0.5">CHATGPT</text>
              <text x="55" y="252" font-family="Clash Display, sans-serif" font-size="12" font-weight="600" fill="currentColor">Nestor S.</text>
              <text x="55" y="268" font-family="Chivo, sans-serif" font-size="10" fill="currentColor" opacity="0.6">nestorsegura.com</text>
            </g>

            <!-- Google bubble -->
            <g>
              <rect x="135" y="210" width="130" height="70" rx="10" fill="var(--brand-purple, oklch(0.58 0.20 290))" />
              <text x="150" y="232" font-family="Chivo, sans-serif" font-size="10" font-weight="600" fill="white" opacity="0.7">GOOGLE</text>
              <text x="150" y="252" font-family="Clash Display, sans-serif" font-size="12" font-weight="600" fill="white">Nestor S.</text>
              <text x="150" y="268" font-family="Chivo, sans-serif" font-size="10" fill="white" opacity="0.75">nestorsegura.com</text>
            </g>

            <!-- Perplexity bubble -->
            <g>
              <rect x="230" y="210" width="130" height="70" rx="10" fill="white" stroke="currentColor" stroke-width="1.2" />
              <text x="245" y="232" font-family="Chivo, sans-serif" font-size="10" font-weight="600" fill="currentColor" opacity="0.5">PERPLEXITY</text>
              <text x="245" y="252" font-family="Clash Display, sans-serif" font-size="12" font-weight="600" fill="currentColor">Nestor S.</text>
              <text x="245" y="268" font-family="Chivo, sans-serif" font-size="10" fill="currentColor" opacity="0.6">nestorsegura.com</text>
            </g>

            <!-- Check badge -->
            <g transform="translate(170,310)">
              <rect width="60" height="60" rx="30" fill="var(--brand-purple, oklch(0.58 0.20 290))" />
              <path d="M20 30 l8 8 l16 -16" stroke="white" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" fill="none" />
            </g>
          </svg>
        </div>
      </aside>
    </div>

    {ctaHref && ctaLabel && (
      <div class="strategy__cta">
        <a href={ctaHref} class="strategy__cta-btn">
          {ctaLabel}
        </a>
      </div>
    )}
  </div>
</section>

<style is:global>
.strategy {
  --brand-purple: oklch(0.58 0.20 290);
  --brand-dark: #131313;

  background-color: #fafaf9;
  padding-top: clamp(4rem, 10vh, 8rem);
  padding-bottom: clamp(4rem, 10vh, 8rem);
}

.strategy__inner {
  max-width: 80rem;
  margin: 0 auto;
  padding: 0 1.5rem;
}

.strategy__header {
  max-width: 48rem;
  margin-bottom: clamp(3rem, 8vh, 6rem);
}

.strategy__eyebrow {
  display: inline-block;
  font-family: 'Chivo', sans-serif;
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--brand-purple);
  margin-bottom: 1rem;
}

.strategy__headline {
  font-family: 'Clash Display', sans-serif;
  font-size: clamp(2rem, 4.5vw, 3.25rem);
  font-weight: 600;
  line-height: 1.05;
  letter-spacing: -0.02em;
  color: var(--brand-dark);
  margin: 0;
}

.strategy__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 3rem;
  align-items: start;
}

@media (min-width: 900px) {
  .strategy__grid {
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 5rem;
  }
}

.strategy__pillars {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: clamp(4rem, 12vh, 9rem);
}

.pillar {
  position: relative;
  padding-left: 0;
}

.pillar__number {
  display: block;
  font-family: 'Clash Display', sans-serif;
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--brand-purple);
  margin-bottom: 0.75rem;
  letter-spacing: 0.04em;
}

.pillar__title {
  font-family: 'Clash Display', sans-serif;
  font-size: clamp(1.5rem, 3vw, 2rem);
  font-weight: 600;
  line-height: 1.1;
  letter-spacing: -0.015em;
  color: var(--brand-dark);
  margin: 0 0 0.75rem 0;
}

.pillar__lead {
  font-family: 'Clash Display', sans-serif;
  font-size: clamp(1rem, 1.4vw, 1.125rem);
  font-weight: 500;
  line-height: 1.4;
  color: var(--brand-purple);
  margin: 0 0 1rem 0;
}

.pillar__body {
  font-family: 'Chivo', sans-serif;
  font-size: 1rem;
  line-height: 1.6;
  color: #3a3a3a;
  margin: 0;
  max-width: 32rem;
}

.strategy__stage {
  display: none;
}

@media (min-width: 900px) {
  .strategy__stage {
    display: block;
    color: var(--brand-dark);
    align-self: stretch;
    height: 100%;
  }
}

.strategy__sticky {
  position: sticky;
  top: 6.5rem;
  aspect-ratio: 1 / 1;
  width: 100%;
  max-width: 28rem;
  margin: 0 auto;
  background: white;
  border-radius: 1.5rem;
  box-shadow: 0 2px 24px rgba(0, 0, 0, 0.06);
  overflow: hidden;
  display: grid;
  place-items: center;
  padding: 1.5rem;
}

.illo {
  grid-area: 1 / 1;
  width: 100%;
  height: 100%;
  opacity: 0;
  transform: scale(0.96);
  transition: opacity 0.45s ease, transform 0.45s ease;
  color: var(--brand-dark);
}

.illo.is-active {
  opacity: 1;
  transform: scale(1);
}

/* Mobile: show all illos inline with their pillars */
@media (max-width: 899px) {
  .pillar::after {
    content: '';
    display: block;
    margin-top: 2rem;
    aspect-ratio: 4 / 3;
    background: white;
    border-radius: 1rem;
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.05);
  }
}

.strategy__cta {
  margin-top: clamp(3rem, 10vh, 6rem);
  text-align: center;
}

.strategy__cta-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background: var(--brand-purple);
  color: white;
  font-family: 'Clash Display', sans-serif;
  font-weight: 600;
  font-size: 1rem;
  padding: 1rem 1.75rem;
  border-radius: 999px;
  text-decoration: none;
  transition: transform 0.18s ease, background-color 0.18s ease;
}

.strategy__cta-btn:hover {
  background: oklch(0.50 0.22 290);
  transform: translateY(-1px);
}
</style>

<script is:inline>
  (function () {
    var pillars = document.querySelectorAll('[data-pillar-index]');
    var illos = document.querySelectorAll('.illo[data-illo]');
    if (!pillars.length || !illos.length) return;

    function setActive(name) {
      illos.forEach(function (el) {
        if (el.getAttribute('data-illo') === name) el.classList.add('is-active');
        else el.classList.remove('is-active');
      });
    }

    // Initial state: first illustration active
    setActive(pillars[0].getAttribute('data-pillar-illo'));

    var io = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            setActive(entry.target.getAttribute('data-pillar-illo'));
          }
        });
      },
      { rootMargin: '-45% 0px -45% 0px', threshold: 0 }
    );

    pillars.forEach(function (p) { io.observe(p); });
  })();
</script>
