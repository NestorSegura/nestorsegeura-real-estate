---
import type { Locale } from '../../i18n/utils'
import StackingCards from './StackingCards.astro'

interface ProblemItem {
  _key?: string
  number?: string
  title?: string
  description?: string
}

interface Props {
  locale: Locale
  headline?: string
  intro?: string
  problems?: ProblemItem[]
  closing?: string
  [key: string]: unknown
}

const { headline, intro, problems = [], closing } = Astro.props

// Problem index → brand card background. Cycles through lilac, purple, dark, teal.
const cardColorClass = ['is--lilac', 'is--green', 'is--dark', 'is--teal']
---

<section id="problem" class="bg-white">
  <div class="max-w-6xl mx-auto px-6 pt-16 md:pt-24">
    {headline && (
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        {headline}
      </h2>
    )}

    {intro && (
      <p class="text-lg text-gray-600 max-w-2xl mb-8 leading-relaxed">
        {intro}
      </p>
    )}
  </div>

  {problems.length > 0 && (
    <StackingCards
      variant="narrow"
      desktopRotate="-5, 2, 6, -3"
      desktopX="-13.75em, 0em, 13em, 6em"
      desktopY="2.125em, 0em, 4.5em, 8em"
    >
      {problems.map((problem, index) => {
        const colorClass = cardColorClass[index % cardColorClass.length]
        return (
        <div data-stacking-card class="cards-stack__item">
          <div data-stacking-card-target class={`cards-stack-card${colorClass ? ' ' + colorClass : ''}`}>
            <span
              class="card-number text-primary-200"
              aria-hidden="true"
            >
              {problem.number ?? ''}
            </span>
            {problem.title && (
              <h3 class="text-xl font-bold text-gray-900 mt-4 mb-2">{problem.title}</h3>
            )}
            {problem.description && (
              <p class="text-base text-gray-600 leading-relaxed">{problem.description}</p>
            )}
          </div>
        </div>
        )
      })}
    </StackingCards>
  )}

  {closing && (
    <div class="max-w-6xl mx-auto px-6 pb-16 md:pb-24">
      <p class="mt-8 text-lg font-medium text-primary-700 text-center">
        {closing}
      </p>
    </div>
  )}
</section>
