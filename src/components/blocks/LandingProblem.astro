---
import type { Locale } from '../../i18n/utils'
import StackingCards from './StackingCards.astro'

interface ProblemItem {
  _key?: string
  number?: string
  title?: string
  description?: string
}

interface Props {
  locale: Locale
  headline?: string
  intro?: string
  problems?: ProblemItem[]
  closing?: string
  [key: string]: unknown
}

const { headline, intro, problems = [], closing } = Astro.props

// Problem index → brand card background. Cycles through lilac, purple, dark, teal.
const cardColorClass = ['is--lilac', 'is--green', 'is--dark', 'is--teal']
---

<section id="problem" class="bg-white">
  <div class="max-w-[72em] mx-auto px-[1.5em] pt-[4em] md:pt-[6em]">
    {headline && (
      <h2 class="text-[1.875em] md:text-[2.25em] font-bold text-gray-900 mb-[1em]">
        {headline}
      </h2>
    )}

    {intro && (
      <p class="text-[1.125em] text-gray-600 max-w-[42em] mb-[2em] leading-relaxed">
        {intro}
      </p>
    )}
  </div>

  {problems.length > 0 && (
    <StackingCards
      variant="narrow"
      desktopRotate="-5, 2, 6, -3"
      desktopX="-13.75em, 0em, 13em, 6em"
      desktopY="2.125em, 0em, 4.5em, 8em"
    >
      {problems.map((problem, index) => {
        const colorClass = cardColorClass[index % cardColorClass.length]
        return (
        <div data-stacking-card class="cards-stack__item">
          <div data-stacking-card-target class={`cards-stack-card${colorClass ? ' ' + colorClass : ''}`}>
            <span
              class="card-number text-primary-200"
              aria-hidden="true"
            >
              {problem.number ?? ''}
            </span>
            {problem.title && (
              <h3 class="text-[1.25em] font-bold text-gray-900 mt-[1em] mb-[0.5em]">{problem.title}</h3>
            )}
            {problem.description && (
              <p class="text-[1.3em] text-gray-600 leading-relaxed">{problem.description}</p>
            )}
          </div>
        </div>
        )
      })}
    </StackingCards>
  )}

  {closing && (
    <div class="max-w-[72em] mx-auto px-[1.5em] pb-[4em] md:pb-[6em]">
      <p class="mt-[2em] text-[1.125em] font-medium text-primary-700 text-center">
        {closing}
      </p>
    </div>
  )}
</section>
