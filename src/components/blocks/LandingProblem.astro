---
import type { Locale } from '../../i18n/utils'

interface ProblemItem {
  _key?: string
  number?: string
  title?: string
  description?: string
}

interface Props {
  locale: Locale
  headline?: string
  intro?: string
  problems?: ProblemItem[]
  closing?: string
  [key: string]: unknown
}

const { headline, intro, problems = [], closing } = Astro.props
---

<section id="problem" class="bg-white py-16 md:py-24 px-6">
  <div class="max-w-6xl mx-auto">
    {headline && (
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        {headline}
      </h2>
    )}

    {intro && (
      <p class="text-lg text-gray-600 max-w-2xl mb-16 leading-relaxed">
        {intro}
      </p>
    )}

    {problems.length > 0 && (
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        {problems.map((problem) => (
          <div class="flex flex-col gap-4 p-8 rounded-2xl bg-gray-50 border border-gray-100">
            <span
              class="text-7xl font-black leading-none tabular-nums select-none text-primary-200"
              aria-hidden="true"
            >
              {problem.number ?? ''}
            </span>
            {problem.title && (
              <h3 class="text-xl font-bold text-gray-900">{problem.title}</h3>
            )}
            {problem.description && (
              <p class="text-base text-gray-600 leading-relaxed">{problem.description}</p>
            )}
          </div>
        ))}
      </div>
    )}

    {closing && (
      <p class="mt-12 text-lg font-medium text-primary-700 text-center">
        {closing}
      </p>
    )}
  </div>
</section>
