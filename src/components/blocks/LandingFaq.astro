---
import type { Locale } from '../../i18n/utils'

interface FaqItem {
  _key?: string
  question?: string
  answer?: string
}

interface Props {
  locale: Locale
  headline?: string
  faqs?: FaqItem[]
  [key: string]: unknown
}

const { headline, faqs = [] } = Astro.props
---

<section id="faq" class="bg-gray-50 py-[4em] md:py-[6em] px-[1.5em]">
  <div class="max-w-[48em] mx-auto">
    {headline && (
      <h2 class="text-[1.875em] md:text-[2.25em] font-bold text-gray-900 mb-[3em]">
        {headline}
      </h2>
    )}

    {faqs.length > 0 && (
      <div class="flex flex-col gap-[0.75em]">
        {faqs.map((faq) => (
          <details class="faq-item bg-white border border-gray-200 rounded-xl overflow-hidden">
            <summary class="flex items-center justify-between gap-[1em] px-[1.5em] py-[1.25em] cursor-pointer font-semibold text-[1em] text-gray-900 select-none list-none">
              <span>{faq.question}</span>
              <span class="faq-icon shrink-0 w-6 h-6 flex items-center justify-center text-primary-600 font-bold text-[1.25em] leading-none" aria-hidden="true">+</span>
            </summary>
            <p class="px-[1.5em] pb-[1.25em] text-[1em] text-gray-600 leading-relaxed">
              {faq.answer}
            </p>
          </details>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  details summary {
    cursor: pointer;
    list-style: none;
  }

  details summary::-webkit-details-marker {
    display: none;
  }

  details[open] .faq-icon {
    transform: rotate(45deg);
    transition: transform 0.2s ease;
  }

  .faq-icon {
    transition: transform 0.2s ease;
  }
</style>
