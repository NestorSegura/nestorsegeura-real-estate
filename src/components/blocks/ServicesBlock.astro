---
import type { Locale } from '../../i18n/utils'
import Button from '../ui/Button.astro'

interface ServiceItem {
  _key?: string
  number?: string
  name?: string
  description?: string
  features?: string[]
  ctaLabel?: string
  ctaHref?: string
}

interface Props {
  locale: Locale
  title?: string
  services?: ServiceItem[]
  colorScheme?: 'light' | 'dark'
  [key: string]: unknown
}

const { title, services = [], colorScheme = 'light' } = Astro.props

const isDark = colorScheme === 'dark'
const sectionClass = isDark ? 'bg-primary-900 text-white' : 'bg-gray-50 text-gray-900'
const cardClass = isDark
  ? 'bg-primary-800/50 border-primary-700/40 text-white'
  : 'bg-white border-gray-200 text-gray-900'
const descClass = isDark ? 'text-primary-200' : 'text-gray-600'
const featureClass = isDark ? 'text-primary-200' : 'text-gray-700'
---

<section id="services" class={`${sectionClass} py-[4em] md:py-[6em] px-[1.5em]`}>
  <div class="max-w-[72em] mx-auto">
    {title && (
      <h2 class="text-[1.875em] md:text-[2.25em] font-bold mb-[3em]">
        {title}
      </h2>
    )}

    {services.length > 0 && (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-[2em]">
        {services.map((service) => (
          <div class={`flex flex-col gap-[1.25em] p-[2em] rounded-2xl border ${cardClass}`}>
            {service.number && (
              <span
                class="text-[3em] font-black leading-none tabular-nums select-none text-primary-300"
                aria-hidden="true"
              >
                {service.number}
              </span>
            )}

            {service.name && (
              <h3 class="text-[1.25em] font-bold">{service.name}</h3>
            )}

            {service.description && (
              <p class={`text-[1em] leading-relaxed ${descClass}`}>{service.description}</p>
            )}

            {service.features && service.features.length > 0 && (
              <ul class="flex flex-col gap-[0.5em] mt-auto">
                {service.features.map((feat) => (
                  <li class={`flex items-start gap-[0.5em] text-[0.875em] ${featureClass}`}>
                    <span class="text-primary-400 shrink-0 mt-[0.125em]" aria-hidden="true">✓</span>
                    <span>{feat}</span>
                  </li>
                ))}
              </ul>
            )}

            {service.ctaHref && service.ctaLabel && (
              <div class="mt-auto">
                <Button href={service.ctaHref} label={service.ctaLabel} variant="filled" tone="primary" />
              </div>
            )}
          </div>
        ))}
      </div>
    )}
  </div>
</section>
