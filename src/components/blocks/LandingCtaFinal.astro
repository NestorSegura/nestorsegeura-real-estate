---
import type { Locale } from '../../i18n/utils'
import Button from '../ui/Button.astro'

interface Props {
  locale: Locale
  headline?: string
  copy?: string
  ctaLabel?: string
  ctaHref?: string
  scarcityText?: string
  [key: string]: unknown
}

const { headline, copy, ctaLabel, ctaHref, scarcityText } = Astro.props
---

<section id="cta-final" class="bg-primary-900 py-16 md:py-24 px-6 text-center">
  <div class="max-w-3xl mx-auto">
    {headline && (
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6 leading-tight">
        {headline}
      </h2>
    )}

    {copy && (
      <p class="text-lg md:text-xl text-white/80 mb-10 leading-relaxed">
        {copy}
      </p>
    )}

    {ctaHref && ctaLabel && (
      <Button href={ctaHref} label={ctaLabel} variant="filled" size="large" tone="white" />
    )}

    {scarcityText && (
      <p class="mt-4 text-sm text-primary-300">
        {scarcityText}
      </p>
    )}
  </div>
</section>
