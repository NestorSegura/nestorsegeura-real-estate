---
import type { Locale } from '../../i18n/utils'

interface Props {
  locale: Locale
  headline?: string
  copy?: string
  ctaLabel?: string
  ctaHref?: string
  scarcityText?: string
  [key: string]: unknown
}

const { headline, copy, ctaLabel, ctaHref, scarcityText } = Astro.props
---

<section id="cta-final" class="bg-primary-900 py-16 md:py-24 px-6 text-center">
  <div class="max-w-3xl mx-auto">
    {headline && (
      <h2 class="text-3xl md:text-5xl font-bold text-white mb-6 leading-tight">
        {headline}
      </h2>
    )}

    {copy && (
      <p class="text-lg md:text-xl text-white/80 mb-10 leading-relaxed">
        {copy}
      </p>
    )}

    {ctaHref && ctaLabel && (
      <a
        href={ctaHref}
        class="inline-block bg-primary-700 hover:bg-primary-800 text-white font-semibold text-xl px-8 py-4 rounded-lg transition-all duration-200 hover:-translate-y-px"
      >
        {ctaLabel}
      </a>
    )}

    {scarcityText && (
      <p class="mt-4 text-sm text-primary-300">
        {scarcityText}
      </p>
    )}
  </div>
</section>
