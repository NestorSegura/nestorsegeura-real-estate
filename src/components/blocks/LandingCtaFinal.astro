---
import type { Locale } from '../../i18n/utils'
import Button from '../ui/Button.astro'

interface Props {
  locale: Locale
  headline?: string
  copy?: string
  ctaLabel?: string
  ctaHref?: string
  scarcityText?: string
  [key: string]: unknown
}

const { headline, copy, ctaLabel, ctaHref, scarcityText } = Astro.props
---

<section id="cta-final" class="bg-primary-900 py-[4em] md:py-[6em] px-[1.5em] text-center">
  <div class="max-w-[48em] mx-auto">
    {headline && (
      <h2 class="text-[1.875em] md:text-[2.25em] font-bold text-white mb-[1.5em] leading-tight">
        {headline}
      </h2>
    )}

    {copy && (
      <p class="text-[1.125em] md:text-[1.25em] text-white/80 mb-[2.5em] leading-relaxed">
        {copy}
      </p>
    )}

    {ctaHref && ctaLabel && (
      <Button href={ctaHref} label={ctaLabel} variant="filled" size="large" tone="white" />
    )}

    {scarcityText && (
      <p class="mt-[1em] text-[0.875em] text-primary-300">
        {scarcityText}
      </p>
    )}
  </div>
</section>
