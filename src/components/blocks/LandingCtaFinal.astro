---
import type { Locale } from '../../i18n/utils'
import Button from '../ui/Button.astro'
import SectionHeader from '../ui/SectionHeader.astro'
import { getBookingUrl } from '../../lib/booking'

interface Props {
  locale: Locale
  headline?: string
  copy?: string
  ctaLabel?: string
  ctaHref?: string
  scarcityText?: string
  [key: string]: unknown
}

const { locale, headline, copy, ctaLabel, scarcityText } = Astro.props

const ctaHref = getBookingUrl(locale)
---

<section id="cta-final" class="bg-primary-900 py-[4em] md:py-[6em] px-[1.5em] text-center">
  <div class="max-w-[48em] mx-auto">
    {headline && (
      <SectionHeader headline={headline} align="center" tone="light" marginBottom="1.5em" />
    )}

    {copy && (
      <p class="text-[1.125em] md:text-[1.25em] text-white/80 mb-[2.5em] leading-relaxed">
        {copy}
      </p>
    )}

    {ctaHref && ctaLabel && (
      <Button href={ctaHref} label={ctaLabel} variant="filled" size="large" tone="white" />
    )}

    {scarcityText && (
      <p class="mt-[1em] text-[0.875em] text-primary-300">
        {scarcityText}
      </p>
    )}
  </div>
</section>
