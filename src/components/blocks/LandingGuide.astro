---
import type { Locale } from '../../i18n/utils'
import { urlFor } from '../../lib/imageUrl'
import SectionHeader from '../ui/SectionHeader.astro'

interface Props {
  locale: Locale
  headline?: string
  paragraphs?: string[]
  image?: { asset?: { _ref: string; _id: string } } | null
  // testimonials kept in props for backwards-compat with the Sanity schema
  // but no longer rendered — there's a dedicated TestimonialsBlock elsewhere.
  testimonials?: unknown[]
  [key: string]: unknown
}

const { locale, headline, paragraphs = [], image } = Astro.props

const eyebrowCopy: Record<Locale, string> = {
  de: 'Mein Ansatz',
  en: 'My approach',
  es: 'Mi enfoque',
}
const eyebrow = eyebrowCopy[locale] ?? eyebrowCopy.de

const imageSrc = urlFor(image as any)?.width(640).format('webp').url() ?? null
const imageSrcset = imageSrc
  ? [640, 960, 1280]
      .map((w) => `${urlFor(image as any)?.width(w).format('webp').url()} ${w}w`)
      .join(', ')
  : null
---

<section id="guide" class="guide-editorial">
  <div class="guide-editorial__inner">
    {headline && (
      <SectionHeader
        headline={headline}
        eyebrow={eyebrow}
        align="left"
        class="guide-editorial__header"
      />
    )}

    {paragraphs.length > 0 && (
      <p data-highlight-text class="guide-editorial__paragraph">
        {paragraphs.map((p, i) => (
          <>
            {p}
            {i < paragraphs.length - 1 && (
              <>
                <br />
                <br />
              </>
            )}
          </>
        ))}
      </p>
    )}

    {imageSrc && (
      <div class="guide-editorial__media">
        <img
          src={imageSrc}
          srcset={imageSrcset ?? undefined}
          sizes="(min-width: 1024px) 80vw, 100vw"
          width="640"
          height="640"
          loading="lazy"
          alt={headline ?? ''}
          class="guide-editorial__image"
        />
      </div>
    )}
  </div>
</section>

<style>
  .guide-editorial {
    background: #fff;
    padding: 8rem 1.5rem;
    color: var(--color-brand-dark, #131313);
  }

  @media (max-width: 760px) {
    .guide-editorial { padding: 5rem 1.25rem; }
  }

  .guide-editorial__inner {
    max-width: 88rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 5rem;
  }

  /* Heading uses .section-h2 utility from global.css; component-local
     style only adds layout constraints. */
  .guide-editorial__header {
    max-width: 38em;
  }
  .guide-editorial__heading {
    color: var(--color-brand-dark, #131313);
  }

  /* The big editorial statement — the focal point of the section.
     Single <p> with <br><br> between original paragraph chunks so the
     SplitText effect treats the whole block as one continuous animation. */
  .guide-editorial__paragraph {
    font-family: 'Clash Display', system-ui, sans-serif;
    font-size: clamp(1.875rem, 4.5vw, 4rem);
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: var(--color-brand-dark, #131313);
    margin: 0;
    text-wrap: balance;
  }

  @media (max-width: 760px) {
    .guide-editorial__inner { gap: 3rem; }
    .guide-editorial__paragraph {
      font-size: clamp(1.625rem, 7vw, 2.5rem);
      line-height: 1.1;
    }
  }

  /* Optional image — sits below as supporting media when present */
  .guide-editorial__media {
    margin-top: 2rem;
  }

  .guide-editorial__image {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 1.5rem;
    box-shadow: 0 10px 40px rgba(19, 19, 19, 0.08);
  }
</style>

<script is:inline>
  /**
   * Osmo highlight-text scroll effect.
   * Each [data-highlight-text] element splits into chars; chars tween from
   * a low opacity to fully visible, scrubbed against ScrollTrigger.
   *
   * Loads GSAP + ScrollTrigger + SplitText lazily from CDN with guards so
   * we don't duplicate scripts already loaded by Footer/StackingCards/MegaNav.
   */
  (function () {
    if (window.__highlightTextInit) return;
    window.__highlightTextInit = true;

    function loadScript(src) {
      return new Promise(function (resolve, reject) {
        if (Array.from(document.scripts).some(function (s) { return s.src === src; })) {
          resolve();
          return;
        }
        var s = document.createElement('script');
        s.src = src;
        s.async = true;
        s.onload = resolve;
        s.onerror = reject;
        document.head.appendChild(s);
      });
    }

    function init() {
      if (!window.gsap || !window.ScrollTrigger || !window.SplitText) return;
      window.gsap.registerPlugin(window.ScrollTrigger, window.SplitText);

      // Bridge Lenis ↔ ScrollTrigger if Lenis booted before GSAP arrived.
      if (window.lenis && !window.__lenisGsapSynced) {
        window.__lenisGsapSynced = true;
        window.lenis.on('scroll', window.ScrollTrigger.update);
        window.gsap.ticker.add(function (time) { window.lenis.raf(time * 1000); });
        window.gsap.ticker.lagSmoothing(0);
        window.ScrollTrigger.refresh();
      }

      document.querySelectorAll('[data-highlight-text]').forEach(function (heading) {
        var scrollStart = heading.getAttribute('data-highlight-scroll-start') || 'top 90%';
        var scrollEnd   = heading.getAttribute('data-highlight-scroll-end')   || 'center 40%';
        var fadedValue  = parseFloat(heading.getAttribute('data-highlight-fade'))    || 0.2;
        var staggerVal  = parseFloat(heading.getAttribute('data-highlight-stagger')) || 0.1;

        new window.SplitText(heading, {
          type: 'words, chars',
          autoSplit: true,
          onSplit: function (self) {
            return window.gsap.context(function () {
              var tl = window.gsap.timeline({
                scrollTrigger: {
                  scrub: true,
                  trigger: heading,
                  start: scrollStart,
                  end: scrollEnd,
                },
              });
              tl.from(self.chars, {
                autoAlpha: fadedValue,
                stagger: staggerVal,
                ease: 'linear',
              });
            });
          },
        });
      });
    }

    function start() {
      var p1 = window.gsap
        ? Promise.resolve()
        : loadScript('https://cdn.jsdelivr.net/npm/gsap@3.15/dist/gsap.min.js');
      p1
        .then(function () {
          return window.ScrollTrigger
            ? Promise.resolve()
            : loadScript('https://cdn.jsdelivr.net/npm/gsap@3.15/dist/ScrollTrigger.min.js');
        })
        .then(function () {
          return window.SplitText
            ? Promise.resolve()
            : loadScript('https://cdn.jsdelivr.net/npm/gsap@3.15/dist/SplitText.min.js');
        })
        .then(init)
        .catch(function () { /* graceful fallback — text stays at full opacity */ });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', start);
    } else {
      start();
    }
  })();
</script>
