---
import type { Locale } from '../../i18n/utils'
import { urlFor } from '../../lib/imageUrl'

interface Props {
  locale: Locale
  headline?: string
  paragraphs?: string[]
  image?: { asset?: { _ref: string; _id: string } } | null
  // testimonials kept in props for backwards-compat with Sanity schema, but
  // intentionally NOT rendered here — there's a dedicated TestimonialsBlock
  // elsewhere on the page. This block now ends in a validation/references rail.
  testimonials?: unknown[]
  [key: string]: unknown
}

const { locale, headline, paragraphs = [], image } = Astro.props

const imageSrc = urlFor(image as any)?.width(640).format('webp').url() ?? null
const imageSrcset = imageSrc
  ? [640, 960, 1280]
      .map((w) => `${urlFor(image as any)?.width(w).format('webp').url()} ${w}w`)
      .join(', ')
  : null

// ── Validation footnote (locale-aware) ─────────────────────────────────
// Inline citation line that reads as a natural author footnote rather than
// a card grid. Each source is a real, evergreen, authoritative link.

const REFS = {
  google: 'https://static.googleusercontent.com/media/guidelines.raterhub.com/en//searchqualityevaluatorguidelines.pdf',
  nar: 'https://www.nar.realtor/research-and-statistics/research-reports/highlights-from-the-profile-of-home-buyers-and-sellers',
  twg: 'https://www.thinkwithgoogle.com/marketing-strategies/search/near-me-searches/',
} as const

interface FootnoteParts {
  intro: string
  google: string
  separator1: string
  nar: string
  separator2: string
  twg: string
  outro: string
}

const footnote: Record<Locale, FootnoteParts> = {
  de: {
    intro: 'Dieser Ansatz stützt sich auf ',
    google: 'Googles Qualitätskriterien für Suchergebnisse',
    separator1: ', die ',
    nar: 'NAR-Studien zum Käuferverhalten',
    separator2: ' und ',
    twg: 'Googles eigene Daten zu lokalen Suchanfragen',
    outro: '.',
  },
  en: {
    intro: 'This approach is grounded in ',
    google: 'Google\u2019s search quality guidelines',
    separator1: ', ',
    nar: 'NAR research on buyer behavior',
    separator2: ', and ',
    twg: 'Google\u2019s own data on local search',
    outro: '.',
  },
  es: {
    intro: 'Este enfoque se apoya en ',
    google: 'las directrices de calidad de Google',
    separator1: ', en ',
    nar: 'las investigaciones de NAR sobre el comportamiento del comprador',
    separator2: ' y en ',
    twg: 'los datos propios de Google sobre búsquedas locales',
    outro: '.',
  },
}

const f = footnote[locale] ?? footnote.de
---

<section id="guide" class="bg-white py-16 md:py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">

      {imageSrc && (
        <div class="order-2 lg:order-1">
          <img
            src={imageSrc}
            srcset={imageSrcset ?? undefined}
            sizes="(min-width: 1024px) 50vw, 100vw"
            width="640"
            height="640"
            loading="lazy"
            alt={headline ?? ''}
            class="w-full rounded-2xl object-cover shadow-lg"
          />
        </div>
      )}

      <div class={imageSrc ? 'order-1 lg:order-2' : 'lg:col-span-2'}>
        {headline && (
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6 leading-tight tracking-tight">
            {headline}
          </h2>
        )}

        {paragraphs.length > 0 && (
          <div class="flex flex-col gap-4">
            {paragraphs.map((p) => (
              <p class="text-base md:text-lg text-gray-600 leading-relaxed">{p}</p>
            ))}

            <p class="guide-footnote">
              {f.intro}<a href={REFS.google} target="_blank" rel="noopener noreferrer" class="guide-footnote__link">{f.google}</a>{f.separator1}<a href={REFS.nar} target="_blank" rel="noopener noreferrer" class="guide-footnote__link">{f.nar}</a>{f.separator2}<a href={REFS.twg} target="_blank" rel="noopener noreferrer" class="guide-footnote__link">{f.twg}</a>{f.outro}
            </p>
          </div>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  /* Conversational footnote — sits as a smaller, lighter paragraph below
     the main body. Source links are inline, brand-purple, animated underline. */
  .guide-footnote {
    margin-top: 1rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(19, 19, 19, 0.08);
    font-size: 0.95rem;
    line-height: 1.55;
    color: rgba(19, 19, 19, 0.55);
    font-style: normal;
  }

  .guide-footnote__link {
    color: var(--color-primary-700, oklch(0.42 0.18 290));
    text-decoration: none;
    background-image: linear-gradient(currentColor, currentColor);
    background-repeat: no-repeat;
    background-size: 100% 1px;
    background-position: 0 100%;
    transition: background-size 0.45s cubic-bezier(0.625, 0.05, 0, 1),
                color 0.2s ease;
  }

  @media (hover: hover) and (pointer: fine) {
    .guide-footnote__link:hover {
      color: var(--color-brand-dark, #131313);
      background-size: 100% 2px;
    }
  }

  .guide-footnote__link:focus-visible {
    outline: 2px solid var(--color-primary-700, oklch(0.42 0.18 290));
    outline-offset: 2px;
    border-radius: 2px;
  }
</style>
