---
import type { Locale } from '../../i18n/utils'
import { urlFor } from '../../lib/imageUrl'

interface Props {
  locale: Locale
  headline?: string
  paragraphs?: string[]
  image?: { asset?: { _ref: string; _id: string } } | null
  // testimonials kept in props for backwards-compat with Sanity schema, but
  // intentionally NOT rendered here — there's a dedicated TestimonialsBlock
  // elsewhere on the page. This block now ends in a validation/references rail.
  testimonials?: unknown[]
  [key: string]: unknown
}

const { locale, headline, paragraphs = [], image } = Astro.props

const imageSrc = urlFor(image as any)?.width(640).format('webp').url() ?? null
const imageSrcset = imageSrc
  ? [640, 960, 1280]
      .map((w) => `${urlFor(image as any)?.width(w).format('webp').url()} ${w}w`)
      .join(', ')
  : null

// ── Validation rail copy (locale-aware) ─────────────────────────────────
// External authoritative sources backing the "strategy over aesthetics"
// approach. All links are evergreen, real, and verifiable.

type Copy = {
  validationEyebrow: string
  validationHeading: string
  refs: { source: string; title: string; href: string }[]
}

const copy: Record<Locale, Copy> = {
  de: {
    validationEyebrow: 'Belege',
    validationHeading: 'Warum dieser Ansatz funktioniert',
    refs: [
      {
        source: 'Google Search Quality Guidelines',
        title: 'Was Google als „hochwertigen Inhalt" bewertet — die Grundlage moderner SEO.',
        href: 'https://static.googleusercontent.com/media/guidelines.raterhub.com/en//searchqualityevaluatorguidelines.pdf',
      },
      {
        source: 'NAR Home Buyer Behavior Report',
        title: 'Wie Käufer und Verkäufer online nach Immobilienexperten suchen.',
        href: 'https://www.nar.realtor/research-and-statistics/research-reports/highlights-from-the-profile-of-home-buyers-and-sellers',
      },
      {
        source: 'Think with Google · Local Insights',
        title: 'Konkrete Daten zum Verhalten lokaler Suchender — direkt von Google.',
        href: 'https://www.thinkwithgoogle.com/marketing-strategies/search/near-me-searches/',
      },
    ],
  },
  en: {
    validationEyebrow: 'Evidence',
    validationHeading: 'Why this approach works',
    refs: [
      {
        source: 'Google Search Quality Guidelines',
        title: 'What Google actually ranks as "high-quality content" — the foundation of modern SEO.',
        href: 'https://static.googleusercontent.com/media/guidelines.raterhub.com/en//searchqualityevaluatorguidelines.pdf',
      },
      {
        source: 'NAR Home Buyer Behavior Report',
        title: 'How buyers and sellers actually search for real estate professionals online.',
        href: 'https://www.nar.realtor/research-and-statistics/research-reports/highlights-from-the-profile-of-home-buyers-and-sellers',
      },
      {
        source: 'Think with Google · Local Insights',
        title: 'Hard data on local-search behavior, straight from the source.',
        href: 'https://www.thinkwithgoogle.com/marketing-strategies/search/near-me-searches/',
      },
    ],
  },
  es: {
    validationEyebrow: 'Evidencia',
    validationHeading: 'Por qué funciona este enfoque',
    refs: [
      {
        source: 'Google Search Quality Guidelines',
        title: 'Qué considera Google realmente «contenido de calidad» — la base del SEO moderno.',
        href: 'https://static.googleusercontent.com/media/guidelines.raterhub.com/en//searchqualityevaluatorguidelines.pdf',
      },
      {
        source: 'NAR Home Buyer Behavior Report',
        title: 'Cómo compradores y vendedores buscan agentes inmobiliarios online.',
        href: 'https://www.nar.realtor/research-and-statistics/research-reports/highlights-from-the-profile-of-home-buyers-and-sellers',
      },
      {
        source: 'Think with Google · Local Insights',
        title: 'Datos concretos sobre búsquedas locales, directamente de Google.',
        href: 'https://www.thinkwithgoogle.com/marketing-strategies/search/near-me-searches/',
      },
    ],
  },
}

const c = copy[locale] ?? copy.de
---

<section id="guide" class="bg-white py-16 md:py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">

      {imageSrc && (
        <div class="order-2 lg:order-1">
          <img
            src={imageSrc}
            srcset={imageSrcset ?? undefined}
            sizes="(min-width: 1024px) 50vw, 100vw"
            width="640"
            height="640"
            loading="lazy"
            alt={headline ?? ''}
            class="w-full rounded-2xl object-cover shadow-lg"
          />
        </div>
      )}

      <div class={imageSrc ? 'order-1 lg:order-2' : 'lg:col-span-2'}>
        {headline && (
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6 leading-tight tracking-tight">
            {headline}
          </h2>
        )}

        {paragraphs.length > 0 && (
          <div class="flex flex-col gap-4">
            {paragraphs.map((p) => (
              <p class="text-base md:text-lg text-gray-600 leading-relaxed">{p}</p>
            ))}
          </div>
        )}
      </div>
    </div>

    <!-- Validation rail — replaces former inline testimonials sub-block -->
    <div class="guide-validation">
      <div class="guide-validation__head">
        <span class="guide-validation__eyebrow">( {c.validationEyebrow} )</span>
        <h3 class="guide-validation__heading">{c.validationHeading}</h3>
      </div>

      <ul class="guide-validation__list">
        {c.refs.map((ref) => (
          <li class="guide-validation__item">
            <a
              href={ref.href}
              target="_blank"
              rel="noopener noreferrer"
              class="guide-validation__link"
            >
              <span class="guide-validation__accent" aria-hidden="true"></span>
              <span class="guide-validation__source">{ref.source}</span>
              <span class="guide-validation__desc">{ref.title}</span>
              <svg class="guide-validation__arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M3 11L11 3M11 3H5M11 3V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .guide-validation {
    margin-top: 4rem;
    padding-top: 3rem;
    border-top: 1px solid rgba(19, 19, 19, 0.08);
  }

  .guide-validation__head {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 2rem;
    max-width: 36rem;
  }

  .guide-validation__eyebrow {
    font-family: 'Clash Display', system-ui, sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    color: rgba(19, 19, 19, 0.5);
    letter-spacing: 0;
  }

  .guide-validation__heading {
    font-family: 'Clash Display', system-ui, sans-serif;
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.015em;
    color: var(--color-brand-dark, #131313);
    margin: 0;
  }

  .guide-validation__list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  @media (max-width: 900px) {
    .guide-validation__list { grid-template-columns: 1fr; }
  }

  .guide-validation__item { margin: 0; }

  .guide-validation__link {
    position: relative;
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    grid-template-areas:
      'source  arrow'
      'desc    desc';
    column-gap: 1rem;
    row-gap: 0.625rem;
    align-items: start;
    padding: 1.5rem 1.5rem 1.5rem 1.5rem;
    background: #fff;
    border: 1px solid rgba(19, 19, 19, 0.08);
    border-radius: 1rem;
    color: var(--color-brand-dark, #131313);
    text-decoration: none;
    overflow: hidden;
    transition: transform 0.4s cubic-bezier(0.625, 0.05, 0, 1),
                border-color 0.3s ease,
                box-shadow 0.4s cubic-bezier(0.625, 0.05, 0, 1);
    height: 100%;
  }

  .guide-validation__accent {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--color-primary-700, oklch(0.42 0.18 290));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.5s cubic-bezier(0.625, 0.05, 0, 1);
  }

  .guide-validation__source {
    grid-area: source;
    font-family: 'Clash Display', system-ui, sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.25;
  }

  .guide-validation__arrow {
    grid-area: arrow;
    color: var(--color-primary-700, oklch(0.42 0.18 290));
    transition: transform 0.4s cubic-bezier(0.625, 0.05, 0, 1);
    flex: none;
  }

  .guide-validation__desc {
    grid-area: desc;
    font-family: 'Chivo', system-ui, sans-serif;
    font-size: 0.875rem;
    line-height: 1.45;
    color: rgba(19, 19, 19, 0.6);
  }

  @media (hover: hover) and (pointer: fine) {
    .guide-validation__link:hover {
      transform: translateY(-2px);
      border-color: rgba(19, 19, 19, 0.16);
      box-shadow:
        0 1px 2px rgba(19, 19, 19, 0.04),
        0 8px 20px rgba(19, 19, 19, 0.06);
    }
    .guide-validation__link:hover .guide-validation__accent {
      transform: scaleX(1);
    }
    .guide-validation__link:hover .guide-validation__arrow {
      transform: translate(2px, -2px);
    }
  }

  .guide-validation__link:focus-visible {
    outline: 2px solid var(--color-primary-700, oklch(0.42 0.18 290));
    outline-offset: 2px;
  }
</style>
