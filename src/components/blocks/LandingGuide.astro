---
import type { Locale } from '../../i18n/utils'
import { urlFor } from '../../lib/imageUrl'

interface TestimonialItem {
  _key?: string
  author?: string
  role?: string
  quote?: string
}

interface Props {
  locale: Locale
  headline?: string
  paragraphs?: string[]
  image?: { asset?: { _ref: string; _id: string } } | null
  testimonials?: TestimonialItem[]
  [key: string]: unknown
}

const { headline, paragraphs = [], image, testimonials = [] } = Astro.props

const imageSrc = urlFor(image as any)?.width(640).format('webp').url() ?? null
const imageSrcset = imageSrc
  ? [640, 960, 1280]
      .map((w) => `${urlFor(image as any)?.width(w).format('webp').url()} ${w}w`)
      .join(', ')
  : null
---

<section id="guide" class="bg-white py-16 md:py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">

      {/* Image column */}
      {imageSrc && (
        <div class="order-2 lg:order-1">
          <img
            src={imageSrc}
            srcset={imageSrcset ?? undefined}
            sizes="(min-width: 1024px) 50vw, 100vw"
            width="640"
            height="640"
            loading="lazy"
            alt={headline ?? ''}
            class="w-full rounded-2xl object-cover shadow-lg"
          />
        </div>
      )}

      {/* Text column */}
      <div class={imageSrc ? 'order-1 lg:order-2' : 'lg:col-span-2'}>
        {headline && (
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
            {headline}
          </h2>
        )}

        {paragraphs.length > 0 && (
          <div class="flex flex-col gap-4 mb-8">
            {paragraphs.map((p) => (
              <p class="text-base md:text-lg text-gray-600 leading-relaxed">{p}</p>
            ))}
          </div>
        )}
      </div>
    </div>

    {/* Testimonials sub-block */}
    {testimonials.length > 0 && (
      <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {testimonials.map((t) => (
          <figure class="bg-gray-50 border border-gray-100 rounded-xl p-6 flex flex-col gap-3">
            <blockquote class="text-sm text-gray-700 leading-relaxed italic">
              &ldquo;{t.quote}&rdquo;
            </blockquote>
            <figcaption class="flex flex-col gap-0.5 mt-auto">
              {t.author && (
                <span class="text-sm font-semibold text-gray-900">{t.author}</span>
              )}
              {t.role && (
                <span class="text-xs text-gray-500">{t.role}</span>
              )}
            </figcaption>
          </figure>
        ))}
      </div>
    )}
  </div>
</section>
