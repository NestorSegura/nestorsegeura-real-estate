---
import type { Locale } from '../../i18n/utils'

interface ReferenceItem {
  _key?: string
  name?: string
  description?: string
  url?: string
}

interface Props {
  locale: Locale
  title?: string
  references?: ReferenceItem[]
  [key: string]: unknown
}

const { title, references = [] } = Astro.props
---

<section id="references" class="bg-gray-50 py-16 md:py-24 px-6">
  <div class="max-w-6xl mx-auto">
    {title && (
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-12 text-center">
        {title}
      </h2>
    )}

    {references.length > 0 && (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {references.map((ref) => {
          const card = (
            <div class="flex flex-col gap-3 p-7 rounded-2xl bg-white border border-gray-200 h-full">
              {ref.name && (
                <h3 class="text-lg font-bold text-gray-900">{ref.name}</h3>
              )}
              {ref.description && (
                <p class="text-sm text-gray-600 leading-relaxed">{ref.description}</p>
              )}
              {ref.url && (
                <span class="mt-auto text-xs font-medium text-primary-600 hover:text-primary-800 transition-colors">
                  Website ansehen →
                </span>
              )}
            </div>
          )
          return ref.url ? (
            <a href={ref.url} target="_blank" rel="noopener noreferrer" class="block group">
              {card}
            </a>
          ) : (
            <div>{card}</div>
          )
        })}
      </div>
    )}
  </div>
</section>
