---
import type { Locale } from '../../i18n/utils'
import { urlFor } from '../../lib/imageUrl'

interface TestimonialItem {
  _key?: string
  author?: string
  role?: string
  quote?: string
  image?: { asset?: { _ref: string; _id: string } } | null
}

interface Props {
  locale: Locale
  title?: string
  testimonials?: TestimonialItem[]
  [key: string]: unknown
}

const { title, testimonials = [] } = Astro.props
---

<section id="testimonials" class="bg-white py-16 md:py-24 px-6">
  <div class="max-w-6xl mx-auto">
    {title && (
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-12">
        {title}
      </h2>
    )}

    {testimonials.length > 0 && (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {testimonials.map((t) => {
          const avatarSrc = urlFor(t.image as any)?.width(160).format('webp').url() ?? null
          const initial = (t.author ?? 'A').charAt(0).toUpperCase()
          return (
            <figure class="flex flex-col gap-4 p-8 rounded-2xl bg-gray-50 border border-gray-100 relative">
              <span class="text-5xl font-serif leading-none select-none absolute top-4 left-6 text-primary-200 opacity-60" aria-hidden="true">
                &ldquo;
              </span>

              <blockquote class="text-base text-gray-700 leading-relaxed pt-6">
                {t.quote}
              </blockquote>

              <figcaption class="flex items-center gap-3 mt-auto pt-4 border-t border-gray-200">
                {avatarSrc ? (
                  <img
                    src={avatarSrc}
                    alt={t.author ?? ''}
                    width="40"
                    height="40"
                    loading="lazy"
                    class="w-10 h-10 rounded-full object-cover shrink-0"
                  />
                ) : (
                  <div class="w-10 h-10 rounded-full bg-primary-100 text-primary-700 flex items-center justify-center text-sm font-bold shrink-0" aria-hidden="true">
                    {initial}
                  </div>
                )}
                <div>
                  {t.author && (
                    <p class="text-sm font-semibold text-gray-900">{t.author}</p>
                  )}
                  {t.role && (
                    <p class="text-xs text-gray-500">{t.role}</p>
                  )}
                </div>
              </figcaption>
            </figure>
          )
        })}
      </div>
    )}
  </div>
</section>
