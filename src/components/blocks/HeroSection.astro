---
import type { Locale } from '../../i18n/utils'
import Button from '../ui/Button.astro'

interface Props {
  locale: Locale
  badge?: string
  headline?: string
  highlightedText?: string
  subheadline?: string
  ctaLabel?: string
  ctaHref?: string
  ctaSecondaryText?: string
  colorScheme?: 'light' | 'dark'
  [key: string]: unknown
}

const {
  badge,
  headline,
  highlightedText,
  subheadline,
  ctaLabel,
  ctaHref,
  ctaSecondaryText,
  colorScheme = 'dark',
} = Astro.props

const isDark = colorScheme === 'dark'
const sectionClass = isDark
  ? 'bg-primary-900 text-white'
  : 'bg-white text-gray-900'

// Split headline around highlightedText for accent rendering
let headlineBefore = headline ?? ''
let headlineHighlight = ''
let headlineAfter = ''
if (headline && highlightedText && headline.includes(highlightedText)) {
  const idx = headline.indexOf(highlightedText)
  headlineBefore = headline.slice(0, idx)
  headlineHighlight = highlightedText
  headlineAfter = headline.slice(idx + highlightedText.length)
}
---

<section id="hero" class={`${sectionClass} py-[6em] lg:py-[8em] px-[1.5em]`}>
  <div class="max-w-[56em] mx-auto text-center">
    {badge && (
      <span class="inline-block mb-[1.5em] px-[1em] py-[0.625em] rounded-full text-[0.875em] font-semibold bg-primary-700/30 text-primary-300 border border-primary-700/40 tracking-wide uppercase">
        {badge}
      </span>
    )}

    {headline && (
      <h1 class="text-[3em] md:text-[3.75em] lg:text-[4.5em] font-bold tracking-tight leading-tight mb-[1.5em]">
        {headlineHighlight ? (
          <>
            {headlineBefore}<span class="text-primary-400">{headlineHighlight}</span>{headlineAfter}
          </>
        ) : headline}
      </h1>
    )}

    {subheadline && (
      <p class={`text-[1.25em] md:text-[1.5em] max-w-[42em] mx-auto mb-[2.5em] leading-relaxed ${isDark ? 'text-white/80' : 'text-gray-600'}`}>
        {subheadline}
      </p>
    )}

    <div class="flex flex-col sm:flex-row gap-[1em] justify-center items-center">
      {ctaHref && ctaLabel && (
        <Button
          href={ctaHref}
          label={ctaLabel}
          variant="filled"
          size="large"
          tone={isDark ? 'white' : 'primary'}
        />
      )}

      {ctaSecondaryText && (
        <p class={`text-[1em] ${isDark ? 'text-primary-300' : 'text-gray-500'}`}>
          {ctaSecondaryText}
        </p>
      )}
    </div>
  </div>
</section>
