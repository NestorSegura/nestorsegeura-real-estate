---
import type { Locale } from '../../i18n/utils'
import StackingCards from './StackingCards.astro'

interface StepItem {
  _key?: string
  number?: string
  title?: string
  description?: string
}

interface Props {
  locale: Locale
  headline?: string
  steps?: StepItem[]
  [key: string]: unknown
}

const { headline, steps = [] } = Astro.props

// Step index → extra card class (Variant 2 wide)
// 0 = lilac (#DDD7F1), 1 = primary purple (is--green), 2 = brand dark
const cardColorClass = ['is--lilac', 'is--green', 'is--dark']
const numberColorClass = ['text-primary-200', 'text-primary-200', 'text-primary-300']
---

<section id="plan" class="bg-gray-50">
  <div class="max-w-5xl mx-auto px-6 pt-16 md:pt-24">
    {headline && (
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-8 text-center">
        {headline}
      </h2>
    )}
  </div>

  {steps.length > 0 && (
    <StackingCards variant="wide">
      {steps.map((step, index) => {
        const colorClass = cardColorClass[index % cardColorClass.length]
        const numClass   = numberColorClass[index % numberColorClass.length]
        return (
          <div data-stacking-card class={`cards-stack__item is--wide`}>
            <div
              data-stacking-card-target
              class={`cards-stack-card is--wide${colorClass ? ' ' + colorClass : ''}`}
            >
              <span class={`card-number ${numClass}`} aria-hidden="true">
                {step.number ?? String(index + 1)}
              </span>
              {step.title && (
                <h3 class="text-2xl md:text-3xl font-bold mt-6 mb-3">{step.title}</h3>
              )}
              {step.description && (
                <p class="text-base leading-relaxed opacity-80">{step.description}</p>
              )}
            </div>
          </div>
        )
      })}
    </StackingCards>
  )}

  <div class="pb-8 md:pb-12"></div>
</section>
