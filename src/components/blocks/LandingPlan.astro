---
import type { Locale } from '../../i18n/utils'

interface StepItem {
  _key?: string
  number?: string
  title?: string
  description?: string
}

interface Props {
  locale: Locale
  headline?: string
  steps?: StepItem[]
  [key: string]: unknown
}

const { headline, steps = [] } = Astro.props

// Step background: 0=white card, 1=primary-600 dark, 2=brand-dark
const stepClasses = [
  'bg-white border border-gray-200 text-gray-900',
  'bg-primary-600 text-white',
  'bg-brand-dark text-white',
]

const stepNumberClasses = [
  'text-primary-200',
  'text-primary-200',
  'text-primary-300',
]
---

<section id="plan" class="bg-gray-50 py-16 md:py-24 px-6">
  <div class="max-w-5xl mx-auto">
    {headline && (
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-12 text-center">
        {headline}
      </h2>
    )}

    {steps.length > 0 && (
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {steps.map((step, index) => {
          const cardClass = stepClasses[index % stepClasses.length]
          const numClass = stepNumberClasses[index % stepNumberClasses.length]
          return (
            <div class={`flex flex-col gap-4 p-8 rounded-2xl shadow-sm ${cardClass}`}>
              <span class={`text-7xl font-black leading-none tabular-nums select-none ${numClass}`} aria-hidden="true">
                {step.number ?? String(index + 1).padStart(2, '0')}
              </span>
              {step.title && (
                <h3 class="text-xl font-bold">{step.title}</h3>
              )}
              {step.description && (
                <p class="text-base leading-relaxed opacity-80">{step.description}</p>
              )}
            </div>
          )
        })}
      </div>
    )}
  </div>
</section>
