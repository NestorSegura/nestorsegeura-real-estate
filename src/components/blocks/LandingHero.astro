---
import type { Locale } from '../../i18n/utils'

interface Props {
  locale: Locale
  headline?: string
  subtitle?: string
  ctaLabel?: string
  ctaHref?: string
  ctaSecondaryLabel?: string
  ctaSecondaryHref?: string
  [key: string]: unknown
}

const {
  headline,
  subtitle,
  ctaLabel,
  ctaHref,
  ctaSecondaryLabel,
  ctaSecondaryHref,
} = Astro.props
---

<section id="hero" class="bg-primary-900 py-24 lg:py-32 px-6">
  <div class="max-w-4xl mx-auto text-center">
    {headline && (
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight text-white leading-tight mb-6">
        {headline}
      </h1>
    )}

    {subtitle && (
      <p class="text-xl md:text-2xl text-white/80 max-w-2xl mx-auto mb-10 leading-relaxed">
        {subtitle}
      </p>
    )}

    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      {ctaHref && ctaLabel && (
        <a
          href={ctaHref}
          class="inline-block bg-primary-700 hover:bg-primary-800 text-white font-semibold text-lg px-8 py-4 rounded-lg transition-all duration-200 hover:-translate-y-px"
        >
          {ctaLabel}
        </a>
      )}

      {ctaSecondaryHref && ctaSecondaryLabel && (
        <a
          href={ctaSecondaryHref}
          class="inline-block border border-primary-300 text-primary-100 hover:bg-primary-800 font-semibold text-lg px-8 py-4 rounded-lg transition-all duration-200 hover:-translate-y-px"
        >
          {ctaSecondaryLabel}
        </a>
      )}
    </div>
  </div>
</section>
