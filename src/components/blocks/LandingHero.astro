---
import type { Locale } from '../../i18n/utils'
import Button from '../ui/Button.astro'

interface Props {
  locale: Locale
  headline?: string
  subtitle?: string
  ctaLabel?: string
  ctaHref?: string
  ctaSecondaryLabel?: string
  ctaSecondaryHref?: string
  [key: string]: unknown
}

const {
  headline,
  subtitle,
  ctaLabel,
  ctaHref,
  ctaSecondaryLabel,
  ctaSecondaryHref,
} = Astro.props
---

<section id="hero" class="hero-mesh bg-primary-900 py-[6em] lg:py-[8em] px-[1.5em] relative overflow-hidden">
  <div class="hero-mesh__layer" aria-hidden="true">
    <span class="hero-mesh__blob hero-mesh__blob--a"></span>
    <span class="hero-mesh__blob hero-mesh__blob--b"></span>
    <span class="hero-mesh__blob hero-mesh__blob--c"></span>
    <span class="hero-mesh__blob hero-mesh__blob--d"></span>
  </div>
  <div class="hero-mesh__grain" aria-hidden="true"></div>

  <div class="max-w-[56em] mx-auto text-center relative z-10">
    {headline && (
      <h1 class="text-[3em] md:text-[3.75em] lg:text-[4.5em] font-bold tracking-tight text-white leading-tight mb-[1.5em]">
        {headline}
      </h1>
    )}

    {subtitle && (
      <p class="text-[1.25em] md:text-[1.5em] text-white/80 max-w-[42em] mx-auto mb-[2.5em] leading-relaxed">
        {subtitle}
      </p>
    )}

    <div class="flex flex-col sm:flex-row gap-[1em] justify-center items-center">
      {ctaHref && ctaLabel && (
        <Button href={ctaHref} label={ctaLabel} variant="filled" size="large" tone="white" />
      )}

      {ctaSecondaryHref && ctaSecondaryLabel && (
        <Button href={ctaSecondaryHref} label={ctaSecondaryLabel} variant="ghost" size="large" tone="white" />
      )}
    </div>
  </div>
</section>

<style>
  /* Hero mesh gradient — subtle drifting blobs over primary-900 base.
     All layers are pointer-events:none and absolutely positioned so they
     never affect content layout. Pure CSS @keyframes — no JS. */

  .hero-mesh {
    isolation: isolate;
  }

  .hero-mesh__layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .hero-mesh__blob {
    position: absolute;
    border-radius: 50%;
    /* Heavy blur turns each disc into a soft glow */
    filter: blur(90px);
    will-change: transform;
    opacity: 0.55;
    mix-blend-mode: screen;
  }

  /* Blob A — primary-500 purple, top-left, sweeping diagonal drift */
  .hero-mesh__blob--a {
    width: 38rem;
    height: 38rem;
    top: -8rem;
    left: -6rem;
    background: oklch(0.58 0.20 290);
    animation: heroBlobA 14s ease-in-out infinite;
  }

  /* Blob B — cyan #2ECFE0, right side, traverses vertically */
  .hero-mesh__blob--b {
    width: 30rem;
    height: 30rem;
    top: 10%;
    right: -6rem;
    background: #2ECFE0;
    opacity: 0.4;
    animation: heroBlobB 16s ease-in-out infinite;
  }

  /* Blob C — primary-700 deep purple, bottom-center, breathes wider */
  .hero-mesh__blob--c {
    width: 42rem;
    height: 42rem;
    bottom: -14rem;
    left: 50%;
    background: oklch(0.42 0.18 290);
    animation: heroBlobC 18s ease-in-out infinite;
  }

  /* Blob D — small cyan accent, fast travel across hero */
  .hero-mesh__blob--d {
    width: 18rem;
    height: 18rem;
    top: 25%;
    left: 30%;
    background: #2ECFE0;
    opacity: 0.28;
    animation: heroBlobD 11s ease-in-out infinite;
  }

  /* Faint film grain — SVG noise data URI baked in.
     Creates a subtle texture so flat blobs don't feel CGI. */
  .hero-mesh__grain {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    opacity: 0.08;
    mix-blend-mode: overlay;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }

  /* Larger travel distances + 3-stop loops so motion is perceptible
     even through 90px blur. Triangular path > simple back-and-forth */
  @keyframes heroBlobA {
    0%   { transform: translate(0, 0) scale(1); }
    33%  { transform: translate(14rem, 4rem) scale(1.2); }
    66%  { transform: translate(8rem, 18rem) scale(0.9); }
    100% { transform: translate(0, 0) scale(1); }
  }
  @keyframes heroBlobB {
    0%   { transform: translate(0, 0) scale(1); }
    33%  { transform: translate(-12rem, 10rem) scale(0.85); }
    66%  { transform: translate(-6rem, -8rem) scale(1.15); }
    100% { transform: translate(0, 0) scale(1); }
  }
  @keyframes heroBlobC {
    0%   { transform: translateX(-50%) scale(1); }
    50%  { transform: translateX(-30%) scale(1.25); }
    100% { transform: translateX(-50%) scale(1); }
  }
  @keyframes heroBlobD {
    0%   { transform: translate(0, 0) scale(1); }
    25%  { transform: translate(20rem, 8rem) scale(1.3); }
    50%  { transform: translate(35rem, -4rem) scale(0.8); }
    75%  { transform: translate(15rem, -12rem) scale(1.1); }
    100% { transform: translate(0, 0) scale(1); }
  }

  /* Respect reduced-motion users — freeze blobs in place */
  @media (prefers-reduced-motion: reduce) {
    .hero-mesh__blob {
      animation: none;
    }
  }
</style>
