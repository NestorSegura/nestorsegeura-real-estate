---
import { type Locale } from '../../i18n/utils';
import { useTranslations } from '../../i18n/utils';
import { localizeRoute } from '../../i18n/routes';

interface Props {
  locale: Locale;
  email?: string;
  linkedinUrl?: string;
}

const {
  locale,
  email = 'hello@realestatestrategy.eu',
  linkedinUrl = 'https://www.linkedin.com/in/nestorsegura/',
} = Astro.props;

const t = useTranslations(locale);
const year = new Date().getFullYear();

const navLinks = [
  { href: localizeRoute('blog', locale), label: t('nav.blog') },
  { href: localizeRoute('analyse', locale), label: locale === 'en' ? 'Analyze' : locale === 'es' ? 'Analizar' : 'Analyse' },
  { href: `${locale === 'de' ? '' : '/' + locale}/#kontakt`, label: t('nav.contact') },
];

const legalLinks = [
  { href: localizeRoute('impressum', locale), label: t('legal.impressumTitle') },
  { href: localizeRoute('datenschutz', locale), label: t('legal.datenschutzTitle') },
  { href: localizeRoute('agb', locale), label: t('legal.agbTitle') },
];

const copyright = t('footer.copyright').replace('{year}', String(year));
---
<footer class="site-footer" aria-labelledby="footer-heading">
  <h2 id="footer-heading" class="visually-hidden">Footer</h2>
  <div class="site-footer__inner">
    <div class="site-footer__brand">
      <a href={locale === 'de' ? '/' : `/${locale}/`} class="site-footer__logo" aria-label="Nestor Segura">
        <span class="site-footer__logo-text">Nestor Segura</span>
      </a>
      <p class="site-footer__tagline">{t('footer.tagline')}</p>
    </div>

    <div class="site-footer__col">
      <h3 class="site-footer__heading">{t('footer.navHeading')}</h3>
      <ul class="site-footer__list">
        {navLinks.map((link) => (
          <li><a href={link.href} class="site-footer__link">{link.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="site-footer__col">
      <h3 class="site-footer__heading">{t('footer.legalHeading')}</h3>
      <ul class="site-footer__list">
        {legalLinks.map((link) => (
          <li><a href={link.href} class="site-footer__link">{link.label}</a></li>
        ))}
        <li>
          <button type="button" class="site-footer__link site-footer__link--button" data-cookie-settings-open>
            {t('footer.cookieSettings')}
          </button>
        </li>
      </ul>
    </div>

    <div class="site-footer__col">
      <h3 class="site-footer__heading">{t('footer.contactHeading')}</h3>
      <ul class="site-footer__list">
        <li><a href={`mailto:${email}`} class="site-footer__link">{t('footer.email')}</a></li>
        <li><a href={linkedinUrl} rel="noopener noreferrer" target="_blank" class="site-footer__link">{t('footer.linkedin')}</a></li>
      </ul>
    </div>
  </div>

  <div class="site-footer__bottom">
    <small class="site-footer__copyright">{copyright}</small>
  </div>
</footer>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .site-footer {
    padding: 4rem 1.5rem 2rem;
    background: #131313;
    color: #efeeec;
  }

  .site-footer__inner {
    max-width: 80rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr repeat(3, 1fr);
    gap: 3rem;
  }

  @media (max-width: 900px) {
    .site-footer__inner {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
    }
    .site-footer__brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 560px) {
    .site-footer__inner {
      grid-template-columns: 1fr;
    }
    .site-footer {
      padding: 3rem 1.25rem 1.5rem;
    }
  }

  .site-footer__brand {
    max-width: 22rem;
  }

  .site-footer__logo {
    color: inherit;
    text-decoration: none;
    display: inline-block;
  }

  .site-footer__logo-text {
    font-family: 'Clash Display', system-ui, sans-serif;
    font-size: 1.75rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .site-footer__tagline {
    margin-top: 1rem;
    font-size: 0.95rem;
    line-height: 1.5;
    color: rgba(239, 238, 236, 0.7);
  }

  .site-footer__heading {
    font-family: 'Clash Display', system-ui, sans-serif;
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(239, 238, 236, 0.55);
    margin: 0 0 1.25rem;
  }

  .site-footer__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .site-footer__link {
    color: inherit;
    text-decoration: none;
    font-size: 0.95rem;
    line-height: 1.4;
    transition: color 0.2s ease;
  }

  .site-footer__link:hover,
  .site-footer__link:focus-visible {
    color: #fff;
    text-decoration: underline;
  }

  .site-footer__link--button {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    font: inherit;
    text-align: left;
  }

  .site-footer__bottom {
    max-width: 80rem;
    margin: 3rem auto 0;
    padding-top: 2rem;
    border-top: 1px solid rgba(239, 238, 236, 0.1);
    text-align: center;
  }

  .site-footer__copyright {
    font-size: 0.85rem;
    color: rgba(239, 238, 236, 0.5);
  }
</style>
