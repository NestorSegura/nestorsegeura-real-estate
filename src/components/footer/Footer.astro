---
import { type Locale } from '../../i18n/utils';
import { useTranslations } from '../../i18n/utils';
import { localizeRoute } from '../../i18n/routes';

interface Props {
  locale: Locale;
  email?: string;
  linkedinUrl?: string;
}

const {
  locale,
  email = 'hello@realestatestrategy.eu',
  linkedinUrl = 'https://www.linkedin.com/in/nestorsegura/',
} = Astro.props;

const t = useTranslations(locale);
const year = new Date().getFullYear();

const pagesLinks = [
  { href: locale === 'de' ? '/' : `/${locale}/`, label: t('nav.home') },
  { href: localizeRoute('blog', locale), label: t('nav.blog') },
  { href: localizeRoute('analyse', locale), label: locale === 'en' ? 'Analyze' : locale === 'es' ? 'Analizar' : 'Analyse' },
  { href: `${locale === 'de' ? '' : '/' + locale}/#kontakt`, label: t('nav.contact') },
];

// Short labels for footer column (avoid long words like "Datenschutzerklärung")
const legalShort = {
  de: { impressum: 'Impressum', datenschutz: 'Datenschutz', agb: 'AGB' },
  en: { impressum: 'Imprint', datenschutz: 'Privacy', agb: 'Terms' },
  es: { impressum: 'Aviso', datenschutz: 'Privacidad', agb: 'Términos' },
} as const;

const legalLinks = [
  { href: localizeRoute('impressum', locale), label: legalShort[locale].impressum },
  { href: localizeRoute('datenschutz', locale), label: legalShort[locale].datenschutz },
  { href: localizeRoute('agb', locale), label: legalShort[locale].agb },
];

const eyebrowPages = locale === 'en' ? 'Pages' : locale === 'es' ? 'Páginas' : 'Seiten';
const eyebrowLegal = locale === 'en' ? 'Legal' : locale === 'es' ? 'Legal' : 'Rechtliches';
const eyebrowContact = locale === 'en' ? 'Contact' : locale === 'es' ? 'Contacto' : 'Kontakt';
const eyebrowTagline = t('footer.tagline');

const copyright = t('footer.copyright').replace('{year}', String(year));
---
<div data-footer-parallax class="footer-wrap">
  <footer data-footer-parallax-inner class="demo-footer" aria-labelledby="footer-heading">
    <h2 id="footer-heading" class="visually-hidden">Footer</h2>

    <div class="demo-footer__links-row">
      <div class="demo-footer__col">
        <p class="demo-eyebrow">( {eyebrowPages} )</p>
        <div class="demo-footer__links">
          {pagesLinks.map((link) => (
            <a href={link.href} data-underline-link class="demo-footer__a">{link.label}</a>
          ))}
        </div>
      </div>

      <div class="demo-footer__col">
        <p class="demo-eyebrow">( {eyebrowLegal} )</p>
        <div class="demo-footer__links">
          {legalLinks.map((link) => (
            <a href={link.href} data-underline-link class="demo-footer__a">{link.label}</a>
          ))}
          <button type="button" data-cookie-settings-open data-underline-link class="demo-footer__a demo-footer__a--button">
            {t('footer.cookieSettings')}
          </button>
        </div>
      </div>

      <div class="demo-footer__col">
        <p class="demo-eyebrow">( {eyebrowContact} )</p>
        <div class="demo-footer__links">
          <a href={`mailto:${email}`} data-underline-link class="demo-footer__a demo-footer__a--email">{email}</a>
          <a href={linkedinUrl} target="_blank" rel="noopener noreferrer" data-underline-link class="demo-footer__a">LinkedIn</a>
        </div>
      </div>
    </div>

    <div class="demo-footer__logo-row">
      <p class="demo-eyebrow">{eyebrowTagline}</p>
      <div class="demo-footer__wordmark" aria-hidden="true">
        <span>Nestor Segura</span>
      </div>
      <small class="demo-footer__copyright">{copyright}</small>
    </div>
  </footer>
  <div data-footer-parallax-dark class="footer-wrap__dark"></div>
</div>

<script is:inline>
  (function () {
    if (window.__footerParallaxInit) return;
    window.__footerParallaxInit = true;

    function loadScript(src) {
      return new Promise(function (resolve, reject) {
        if (Array.from(document.scripts).some(function (s) { return s.src === src; })) {
          resolve();
          return;
        }
        var s = document.createElement('script');
        s.src = src;
        s.async = true;
        s.onload = resolve;
        s.onerror = reject;
        document.head.appendChild(s);
      });
    }

    function init() {
      if (!window.gsap || !window.ScrollTrigger) return;
      window.gsap.registerPlugin(window.ScrollTrigger);

      document.querySelectorAll('[data-footer-parallax]').forEach(function (el) {
        var inner = el.querySelector('[data-footer-parallax-inner]');
        var dark = el.querySelector('[data-footer-parallax-dark]');

        var tl = window.gsap.timeline({
          scrollTrigger: {
            trigger: el,
            start: 'clamp(top bottom)',
            end: 'clamp(top top)',
            scrub: true,
          },
        });

        if (inner) {
          tl.from(inner, { yPercent: -25, ease: 'linear' });
        }
        if (dark) {
          tl.from(dark, { opacity: 0.5, ease: 'linear' }, '<');
        }
      });
    }

    function start() {
      var gsapPromise = window.gsap
        ? Promise.resolve()
        : loadScript('https://cdn.jsdelivr.net/npm/gsap@3.15/dist/gsap.min.js');
      gsapPromise
        .then(function () {
          return window.ScrollTrigger
            ? Promise.resolve()
            : loadScript('https://cdn.jsdelivr.net/npm/gsap@3.15/dist/ScrollTrigger.min.js');
        })
        .then(init)
        .catch(function () { /* swallow — footer stays static if GSAP fails */ });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', start);
    } else {
      start();
    }
  })();
</script>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Parallax wrap */
  .footer-wrap {
    position: relative;
    overflow: hidden;
    background: #efeeec;
    color: #131313;
  }

  .footer-wrap__dark {
    opacity: 0;
    pointer-events: none;
    background-color: #131313;
    width: 100%;
    height: 100%;
    position: absolute;
    inset: 0;
    mix-blend-mode: multiply;
  }

  /* Footer core layout (osmo-style) */
  .demo-footer {
    display: flex;
    flex-flow: column;
    justify-content: space-between;
    gap: 7.5em;
    min-height: 100svh;
    padding: 2.5em;
    letter-spacing: -0.02em;
    font-family: 'Clash Display', system-ui, sans-serif;
    font-weight: 600;
    position: relative;
    z-index: 1;
  }

  .demo-eyebrow {
    opacity: 0.5;
    margin-bottom: 0;
    font-size: 1.3125em;
    font-weight: 600;
    letter-spacing: 0;
  }

  .demo-footer__links-row {
    display: flex;
    gap: 2.5em;
  }

  .demo-footer__col {
    display: flex;
    flex-flow: column;
    gap: 3em;
    width: calc(33.3333% - 1.66667em);
  }

  .demo-footer__links {
    display: flex;
    flex-flow: column;
    align-items: flex-start;
    gap: 0.25em;
  }

  .demo-footer__a {
    color: inherit;
    font-size: clamp(1.5rem, 3.2vw, 2.75em);
    font-weight: 600;
    line-height: 1.05;
    text-decoration: none;
    font-family: inherit;
    overflow-wrap: anywhere;
    max-width: 100%;
  }

  .demo-footer__a--email {
    font-size: clamp(1rem, 1.6vw, 1.35em);
    line-height: 1.2;
  }

  .demo-footer__a--button {
    appearance: none;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    text-align: left;
  }

  .demo-footer__logo-row {
    display: flex;
    flex-flow: column;
    gap: 1em;
  }

  .demo-footer__wordmark {
    width: 100%;
    line-height: 0.85;
    font-weight: 700;
    letter-spacing: -0.04em;
    /* Fit to viewport width regardless of content length */
    font-size: clamp(3rem, 11.5vw, 14rem);
    white-space: nowrap;
    overflow: hidden;
  }

  .demo-footer__wordmark span {
    display: inline-block;
    line-height: 1;
  }

  .demo-footer__copyright {
    font-family: 'Chivo', system-ui, sans-serif;
    font-size: 0.85rem;
    font-weight: 400;
    opacity: 0.5;
    letter-spacing: 0;
  }

  /* Osmo-style underline link */
  [data-underline-link] {
    text-decoration: none;
    position: relative;
    display: inline-block;
  }

  [data-underline-link]::before {
    content: '';
    position: absolute;
    bottom: -0.0625em;
    left: 0;
    width: 100%;
    height: 0.06em;
    background-color: currentColor;
    transition: transform 0.735s cubic-bezier(0.625, 0.05, 0, 1);
    transform-origin: right;
    transform: scaleX(0) rotate(0.001deg);
  }

  @media (hover: hover) and (pointer: fine) {
    [data-underline-link]:hover::before {
      transform-origin: left;
      transform: scaleX(1) rotate(0.001deg);
    }
  }

  @media screen and (max-width: 991px) {
    .demo-footer__links-row {
      flex-flow: column;
    }
    .demo-footer__col {
      width: 100%;
    }
    .demo-footer__logo-row {
      gap: 1.5em;
    }
  }

  @media screen and (max-width: 767px) {
    .demo-eyebrow {
      font-size: 1em;
    }
    .demo-footer {
      gap: 5em;
      padding: 1em;
      min-height: 90svh;
    }
    .demo-footer__col {
      gap: 1em;
    }
    .demo-footer__a {
      font-size: 1.75em;
    }
    .demo-footer__wordmark {
      font-size: clamp(3rem, 18vw, 8rem);
    }
  }
</style>
