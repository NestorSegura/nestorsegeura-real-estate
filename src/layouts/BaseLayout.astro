---
import '../styles/global.css';
import { type Locale, DEFAULT_LOCALE } from '../i18n/utils';
import { getSiteSettings } from '../lib/sanity';
import { buildOrganizationSchema } from '../lib/seo';
import JsonLd from '../components/seo/JsonLd.astro';

const SITE_URL =
  (import.meta.env.PUBLIC_SITE_URL as string | undefined) ?? 'https://realestatestrategy.eu';

interface Props {
  title: string;
  locale?: Locale;
  description?: string;
  ogImage?: string;         // full URL
  ogType?: 'website' | 'article';
  canonical?: string;       // full URL
  hreflangUrls?: Record<string, string>;
  jsonLd?: Record<string, unknown>[];  // per-page schemas (Person, Article, Breadcrumb)
}

const {
  title,
  locale = DEFAULT_LOCALE,
  description,
  ogImage,
  ogType = 'website',
  canonical,
  hreflangUrls,
  jsonLd = [],
} = Astro.props;

const canonicalUrl = canonical ?? Astro.url.href;
const resolvedOgImage = ogImage ?? `${SITE_URL}/og-default.png`;

// Fetch siteSettings for Organization JSON-LD (once per page, baked at build time)
const settings = await getSiteSettings();
const orgSchema = buildOrganizationSchema(settings, SITE_URL);
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link
      rel="preload"
      href="/fonts/ClashDisplay-Variable-subset.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/Chivo-Variable-subset.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/lenis@1.2.3/dist/lenis.css" />

    {/* SEO meta — canonical, OG, Twitter, hreflang, sitemap */}
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description ?? ''} />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

    {/* hreflang alternate links */}
    {hreflangUrls && Object.entries(hreflangUrls).map(([lang, href]) => (
      <link rel="alternate" hreflang={lang} href={href} />
    ))}

    {/* Organization JSON-LD — site-wide */}
    <JsonLd schema={orgSchema} />

    {/* Per-page JSON-LD (Person, Article, BreadcrumbList) */}
    {jsonLd.map((schema) => (
      <JsonLd schema={schema} />
    ))}
  </head>
  <body>
    <slot />
    <script src="https://cdn.jsdelivr.net/npm/lenis@1.2.3/dist/lenis.min.js" is:inline></script>
    <script is:inline>
      (function () {
        if (window.__lenisInit) return;
        window.__lenisInit = true;

        function start() {
          if (typeof Lenis === 'undefined') return;

          const lenis = new Lenis();
          window.lenis = lenis;

          // If GSAP + ScrollTrigger are present (loaded by StackingCards), sync them.
          if (window.gsap && window.ScrollTrigger) {
            lenis.on('scroll', window.ScrollTrigger.update);
            window.gsap.ticker.add((time) => lenis.raf(time * 1000));
            window.gsap.ticker.lagSmoothing(0);
          } else {
            // Standalone RAF loop.
            function raf(time) {
              lenis.raf(time);
              requestAnimationFrame(raf);
            }
            requestAnimationFrame(raf);
          }
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', start);
        } else {
          start();
        }
      })();
    </script>
  </body>
</html>
