---
import '../styles/global.css';
import { type Locale, DEFAULT_LOCALE } from '../i18n/utils';
import { getSiteSettings } from '../lib/sanity';
import { localizeRoute } from '../i18n/routes';
import { buildOrganizationSchema } from '../lib/seo';
import JsonLd from '../components/seo/JsonLd.astro';
import MegaNav from '../components/nav/MegaNav.astro';

const SITE_URL =
  (import.meta.env.PUBLIC_SITE_URL as string | undefined) ?? 'https://realestatestrategy.eu';

interface Props {
  title: string;
  locale?: Locale;
  description?: string;
  ogImage?: string;         // full URL
  ogType?: 'website' | 'article';
  canonical?: string;       // full URL
  hreflangUrls?: Record<string, string>;
  jsonLd?: Record<string, unknown>[];  // per-page schemas (Person, Article, Breadcrumb)
  /**
   * Page-specific locale URL map for the locale switcher.
   * Pass this from pages that have cross-locale equivalents (e.g., blog posts via
   * getPostWithTranslations, /analyse pages via localizeRoute('analyse', locale)).
   * When omitted, defaults to each locale's homepage (/, /en/, /es/).
   *
   * Example for /analyse pages:
   *   navLocaleUrls={{ de: '/analyse', en: '/en/analyze', es: '/es/analizar' }}
   *
   * Example for blog posts (computed from _translations):
   *   navLocaleUrls={{ de: '/blog/slug-de', en: '/en/blog/slug-en', es: '/es/blog/slug-es' }}
   */
  navLocaleUrls?: Record<'de' | 'en' | 'es', string>;
}

const {
  title,
  locale = DEFAULT_LOCALE,
  description,
  ogImage,
  ogType = 'website',
  canonical,
  hreflangUrls,
  jsonLd = [],
  navLocaleUrls,
} = Astro.props;

const canonicalUrl = canonical ?? Astro.url.href;
const resolvedOgImage = ogImage ?? `${SITE_URL}/og-default.png`;

// Fetch siteSettings for MegaNav + Organization JSON-LD (once per page, baked at build time)
const settings = await getSiteSettings();
const orgSchema = buildOrganizationSchema(settings, SITE_URL);

// ── MegaNav data ─────────────────────────────────────────────────────────────

// Resolve nav items for the current locale (label fallback chain: locale → de)
const sanityNavItems = (settings?.navItems ?? []).map((item) => {
  const localeKey = `label${locale.charAt(0).toUpperCase() + locale.slice(1)}` as
    | 'labelDe'
    | 'labelEn'
    | 'labelEs';
  const label = (item as Record<string, string>)[localeKey] ?? item.labelDe ?? item.key;

  // Resolve href via localizeRoute if the key is a known route, else use key as path segment
  let href: string;
  try {
    href = localizeRoute(item.key, locale);
  } catch {
    const prefix = locale === DEFAULT_LOCALE ? '' : `/${locale}`;
    href = `${prefix}/${item.key}`;
  }

  return { href, label };
});

const ctaLabel =
  settings?.ctaLabel?.[locale] ??
  settings?.ctaLabel?.['de'] ??
  (locale === 'en' ? 'Book appointment' : locale === 'es' ? 'Reservar cita' : 'Termin buchen');

const ctaHref = settings?.ctaHref ?? '#';

// Locale URLs: use page-specific map if provided, otherwise default to homepages.
// Defined before fallbackNavItems so the Kontakt anchor can reference the homepage root.
const localeUrls: Record<'de' | 'en' | 'es', string> = navLocaleUrls ?? {
  de: localizeRoute('home', 'de'),   // → '/'
  en: localizeRoute('home', 'en'),   // → '/en/'
  es: localizeRoute('home', 'es'),   // → '/es/'
};

// Fallback nav items: used when Sanity siteSettings.navItems is empty (Studio not yet populated).
// Kontakt anchors to the #kontakt section on the current locale's homepage.
const fallbackNavItems = [
  {
    href: localizeRoute('blog', locale),
    label: locale === 'en' ? 'Blog' : locale === 'es' ? 'Blog' : 'Blog',
  },
  {
    href: localizeRoute('analyse', locale),
    label: locale === 'en' ? 'Analyze' : locale === 'es' ? 'Analizar' : 'Analyse',
  },
  {
    // Kontakt: anchor to #kontakt section on the current locale's homepage.
    // Pages that have a dedicated /kontakt route can override via siteSettings navItems.
    href: `${localeUrls[locale]}#kontakt`,
    label: locale === 'en' ? 'Contact' : locale === 'es' ? 'Contacto' : 'Kontakt',
  },
];

const navItems = sanityNavItems.length ? sanityNavItems : fallbackNavItems;
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link
      rel="preload"
      href="/fonts/ClashDisplay-Variable-subset.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/Chivo-Variable-subset.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/lenis@1.2.3/dist/lenis.css" />

    {/* SEO meta — canonical, OG, Twitter, hreflang, sitemap */}
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description ?? ''} />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

    {/* hreflang alternate links */}
    {hreflangUrls && Object.entries(hreflangUrls).map(([lang, href]) => (
      <link rel="alternate" hreflang={lang} href={href} />
    ))}

    {/* Organization JSON-LD — site-wide */}
    <JsonLd schema={orgSchema} />

    {/* Per-page JSON-LD (Person, Article, BreadcrumbList) */}
    {jsonLd.map((schema) => (
      <JsonLd schema={schema} />
    ))}
  </head>
  <body>
    <!-- MegaNav: sticky top nav — osmo mega-nav restyled for brand (Phase 9-02) -->
    <MegaNav
      locale={locale}
      navItems={navItems}
      ctaLabel={ctaLabel}
      ctaHref={ctaHref}
      localeUrls={localeUrls}
    />
    <slot />
    <script src="https://cdn.jsdelivr.net/npm/lenis@1.2.3/dist/lenis.min.js" is:inline></script>
    <script is:inline>
      (function () {
        if (window.__lenisInit) return;
        window.__lenisInit = true;

        function start() {
          if (typeof Lenis === 'undefined') return;

          const lenis = new Lenis();
          window.lenis = lenis;

          // If GSAP + ScrollTrigger are present (loaded by StackingCards), sync them.
          if (window.gsap && window.ScrollTrigger) {
            lenis.on('scroll', window.ScrollTrigger.update);
            window.gsap.ticker.add((time) => lenis.raf(time * 1000));
            window.gsap.ticker.lagSmoothing(0);
          } else {
            // Standalone RAF loop.
            function raf(time) {
              lenis.raf(time);
              requestAnimationFrame(raf);
            }
            requestAnimationFrame(raf);
          }
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', start);
        } else {
          start();
        }
      })();
    </script>
  </body>
</html>
