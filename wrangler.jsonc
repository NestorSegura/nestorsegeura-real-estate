{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "nestorsegura-real-estate",
  "compatibility_date": "2026-03-05",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist/client"
  },
  "observability": {
    "enabled": true
  }
}
